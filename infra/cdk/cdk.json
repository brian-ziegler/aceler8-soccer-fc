{
  "app": "npx ts-node --prefer-ts-exts bin/app.ts",
  "watch": {
    "include": ["**"],
    "exclude": ["README.md", "cdk*.json", "**/*.d.ts", "**/*.js", "tsconfig.json", "package*.json", "yarn.lock", "node_modules", "cdk.out"]
  },
  "context": {
    "@aws-cdk/core:newStyleStackSynthesis": true,
    "bucketName": "aceler8-fc-prod-site",
    "siteDomain": "www.aceler8fc.org",
    "createGithubOidcProvider": false,

    "next:bucketName": "aceler8-fc-next-site",
    "next:siteDomain": "next-version.aceler8fc.com",
    "next:githubOwner": "brian-ziegler",
    "next:githubRepository": "aceler8-soccer-fc",
    "next:githubOidcProviderArn": "arn:aws:iam::125069362169:oidc-provider/token.actions.githubusercontent.com"
  }
}

---
import { siteConfig } from '@/data/site';
import ThemeToggle from '@/components/ThemeToggle.astro';
---

<footer class="site-footer">
  <div class="wrap site-footer__grid">
    <div>
      <img
        src="/logo-wordmark.png"
        alt={siteConfig.name}
        class="site-footer__logo"
        width="160"
        height="60"
      />
      <p class="site-footer__muted">{siteConfig.tagline}</p>
      <p class="site-footer__note">
        This site represents our competitive team. Youth camps and open training programs live at{' '}
        <a href={siteConfig.trainingCampUrl}>aceler8soccer.com</a>.
      </p>
    </div>
    <div>
      <p class="site-footer__heading">Connect</p>
      <ul class="site-footer__list">
        <li>
          <a href={`mailto:${siteConfig.contactEmail}`}>{siteConfig.contactEmail}</a>
        </li>
        <li>
          <a href={siteConfig.instagram} rel="noopener noreferrer">Instagram</a>
        </li>
        <li>
          <a href="/contact/">Contact &amp; verification</a>
        </li>
      </ul>
    </div>
    <div>
      <p class="site-footer__heading">Quick links</p>
      <ul class="site-footer__list">
        <li><a href="/coaches/">Coaching staff</a></li>
        <li><a href="/tournament-directors/">Tournament desk</a></li>
        <li><a href="/schedule/">Schedule</a></li>
      </ul>
    </div>
  </div>
  <div class="site-footer__bar">
    <div class="wrap site-footer__bar-inner">
      <p>© {new Date().getFullYear()} {siteConfig.name}. All rights reserved.</p>
      <div class="site-footer__bar-end">
        <p class="site-footer__muted">Not recruiting at this time.</p>
        <ThemeToggle />
      </div>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: auto;
    border-top: 1px solid var(--color-border);
    background: var(--color-surface);
  }

  .site-footer__grid {
    display: grid;
    gap: 2rem;
    padding-block: 3rem;
    grid-template-columns: repeat(auto-fit, minmax(14rem, 1fr));
  }

  .site-footer__logo {
    display: block;
    height: 3.5rem;
    width: auto;
    margin-bottom: 0.75rem;
    object-fit: contain;
  }

  :global(:root[data-theme='dark']) .site-footer__logo {
    filter: invert(1);
  }

  @media (prefers-color-scheme: dark) {
    :global(:root:not([data-theme])) .site-footer__logo {
      filter: invert(1);
    }
  }

  .site-footer__heading {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin: 0 0 0.75rem;
    color: var(--color-text-muted);
  }

  .site-footer__muted {
    color: var(--color-text-muted);
    margin: 0;
    font-size: 0.95rem;
  }

  .site-footer__note {
    margin-top: 1rem;
    font-size: 0.9rem;
    color: var(--color-text-muted);
    max-width: 28rem;
  }

  .site-footer__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .site-footer__bar {
    border-top: 1px solid var(--color-border);
    background: color-mix(in srgb, var(--color-bg-elevated) 70%, transparent);
  }

  .site-footer__bar-inner {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem 1.5rem;
    align-items: center;
    justify-content: space-between;
    padding-block: 0.75rem;
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  .site-footer__bar-inner p {
    margin: 0;
  }

  .site-footer__bar-end {
    display: flex;
    align-items: center;
    gap: 1rem;
  }
</style>

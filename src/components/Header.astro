---

const pathname = Astro.url.pathname;

const links = [
  { href: '/about/', label: 'About' },
  { href: '/team/', label: 'Team' },
  { href: '/coaches/', label: 'Coaches' },
  { href: '/schedule/', label: 'Schedule' },
  { href: '/tournament-directors/', label: 'Tournament Desk' },
  { href: '/contact/', label: 'Contact' },
];

function isActive(href: string) {
  if (href === '/') return pathname === '/';
  return pathname === href || pathname.startsWith(`${href}/`);
}
---

<header class="site-header">
  <div class="wrap site-header__inner">
    <a class="site-header__brand" href="/">
      <img
        src="/logo-soccer-ball.png"
        alt="Aceler8 Soccer FC"
        class="site-header__logo"
        width="40"
        height="40"
      />
      <span class="site-header__wordmark">
        <span class="site-header__name">Aceler8</span>
        <span class="site-header__sub">Soccer FC</span>
      </span>
    </a>

    <button
      type="button"
      class="site-header__menu-btn"
      aria-expanded="false"
      aria-controls="site-nav"
      id="nav-toggle"
    >
      <span class="sr-only">Open menu</span>
      <span class="site-header__burger" aria-hidden="true"></span>
    </button>

    <nav class="site-nav" id="site-nav" aria-label="Primary">
      <ul class="site-nav__list">
        {
          links.map(({ href, label }) => (
            <li>
              <a href={href} class:list={['site-nav__link', { 'is-active': isActive(href) }]}>
                {label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    height: var(--header-h);
  }

  /* Use ::before for backdrop-filter so position:fixed children
     (the mobile nav) are not trapped in a new containing block. */
  .site-header::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: -1;
    background: color-mix(in srgb, var(--color-bg-elevated) 88%, transparent);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--color-border);
  }

  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 100%;
    gap: 1rem;
  }

  .site-header__brand {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    text-decoration: none;
    color: inherit;
  }

  .site-header__brand:hover {
    color: inherit;
  }

  .site-header__logo {
    width: 2.75rem;
    height: 2.75rem;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
  }

  .site-header__wordmark {
    display: flex;
    flex-direction: column;
    line-height: 1.1;
  }

  .site-header__name {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.15rem;
    letter-spacing: -0.02em;
  }

  .site-header__sub {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .site-header__menu-btn {
    display: none;
    width: 2.75rem;
    height: 2.75rem;
    border-radius: var(--radius-sm);
    border: 1px solid var(--color-border);
    background: var(--color-bg-elevated);
    cursor: pointer;
    align-items: center;
    justify-content: center;
  }

  .site-header__menu-btn:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .site-header__burger {
    width: 1.25rem;
    height: 2px;
    background: var(--color-text);
    position: relative;
  }

  .site-header__burger::before,
  .site-header__burger::after {
    content: '';
    position: absolute;
    left: 0;
    width: 100%;
    height: 2px;
    background: var(--color-text);
    transition: transform 0.2s var(--ease-out);
  }

  .site-header__burger::before {
    top: -6px;
  }

  .site-header__burger::after {
    top: 6px;
  }

  .site-nav {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .site-nav__list {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.25rem 1.25rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .site-nav__link {
    font-size: 0.9rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--color-text-muted);
    padding: 0.35rem 0;
    border-bottom: 2px solid transparent;
    transition:
      color 0.2s var(--ease-out),
      border-color 0.2s var(--ease-out);
  }

  .site-nav__link:hover {
    color: var(--color-text);
  }

  .site-nav__link.is-active {
    color: var(--color-text);
    border-color: var(--color-accent);
  }


  @media (max-width: 960px) {
    .site-header__menu-btn {
      display: inline-flex;
    }

    .site-nav {
      position: fixed;
      z-index: 49;
      inset: var(--header-h) 0 0 0;
      flex-direction: column;
      align-items: stretch;
      padding: 1.5rem;
      background: var(--color-bg-elevated);
      border-bottom: 1px solid var(--color-border);
      transform: translateY(-100%);
      opacity: 0;
      pointer-events: none;
      transition:
        transform 0.35s var(--ease-out),
        opacity 0.25s var(--ease-out);
    }

    .site-nav.is-open {
      transform: translateY(0);
      opacity: 1;
      pointer-events: auto;
    }

    .site-nav__list {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
    }

  }
</style>

<script>
  const toggle = document.getElementById('nav-toggle');
  const nav = document.getElementById('site-nav');
  const body = document.body;

  toggle?.addEventListener('click', () => {
    const open = nav?.classList.toggle('is-open');
    toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
    body.classList.toggle('nav-open', !!open);
  });

  nav?.querySelectorAll('a').forEach((a) => {
    a.addEventListener('click', () => {
      nav.classList.remove('is-open');
      toggle?.setAttribute('aria-expanded', 'false');
      body.classList.remove('nav-open');
    });
  });
</script>

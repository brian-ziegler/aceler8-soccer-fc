---
import { coaches } from '@/data/coaches';

const pathname = Astro.url.pathname;

const links = [
  { href: '/about/', label: 'About' },
  { href: '/teams/', label: 'Teams' },
];

const programDropdown = [
  {
    href: '/programs/#elite',
    label: 'Aceler8 FC Elite',
    highlights: ['4 sessions per week', 'Single team commitment', 'Top league & tournament play', 'U8 and up'],
  },
  {
    href: '/programs/#pathway',
    label: 'Aceler8 FC Pathway',
    highlights: ['2 sessions per week', 'Flexible — works with your current team', 'Direct path to Elite', 'Starting August 2026'],
  },
  {
    href: '/programs/#evaluations',
    label: 'Player Evaluations',
    highlights: ['Monday, June 8th', '5:00–6:30 PM at Grace & Truth', '2015 girls', 'Pathway Program placement'],
  },
  {
    href: '/programs/#training',
    label: 'Aceler8 Training Sessions',
    highlights: ['9-week program', 'Open to all players', 'No tryouts required', 'Individual attention in group setting'],
  },
  {
    href: '/programs/#camps',
    label: 'Summer Camps',
    highlights: ['Sweden Town Park, Brockport', 'Ages 6–13 and 14–18', 'July 2026', '$200 per player'],
  },
  {
    href: '/programs/#clinics',
    label: 'Free Clinics',
    highlights: ['Free — no cost', 'Open to all skill levels', 'Real Aceler8 coaching', 'Community events throughout the year'],
  },
];

function isActive(href: string) {
  if (href === '/') return pathname === '/';
  return pathname === href || pathname.startsWith(`${href}/`);
}

const isProgramsActive = isActive('/programs/') || isActive('/pathway/') || isActive('/camps/');
const isCoachesActive  = isActive('/coaches/');
---

<header class="site-header">
  <div class="wrap site-header__inner">
    <a class="site-header__brand" href="/">
      <img
        src="/logo-soccer-ball.png"
        alt=""
        class="site-header__logo"
        width="48"
        height="48"
      />
    </a>

    <button
      type="button"
      class="site-header__menu-btn"
      aria-expanded="false"
      aria-controls="site-nav"
      id="nav-toggle"
    >
      <span class="sr-only">Open menu</span>
      <span class="site-header__burger" aria-hidden="true"></span>
    </button>

    <nav class="site-nav" id="site-nav" aria-label="Primary">
      <ul class="site-nav__list">
        {
          links.map(({ href, label }) => (
            <li>
              <a href={href} class:list={['site-nav__link', { 'is-active': isActive(href) }]}>
                {label}
              </a>
            </li>
          ))
        }

        <!-- Programs dropdown -->
        <li class="site-nav__has-dropdown">
          <a
            href="/programs/"
            class:list={['site-nav__link', { 'is-active': isProgramsActive }]}
            aria-haspopup="true"
            id="programs-trigger"
          >
            Programs
          </a>
          <div class="programs-dropdown" id="programs-dropdown" role="region" aria-label="Programs menu">
            {programDropdown.map((item) => (
              <a href={item.href} class="dropdown-item">
                <strong class="dropdown-item__name">{item.label}</strong>
                <ul class="dropdown-item__highlights">
                  {item.highlights.map((h) => <li>{h}</li>)}
                </ul>
              </a>
            ))}
          </div>
        </li>

        <!-- Coaches dropdown -->
        <li class="site-nav__has-dropdown">
          <a
            href="/coaches/"
            class:list={['site-nav__link', { 'is-active': isCoachesActive }]}
            aria-haspopup="true"
            id="coaches-trigger"
          >
            Coaches
          </a>
          <div class="coaches-dropdown" id="coaches-dropdown" role="region" aria-label="Coaches menu">
            <a href="/coaches/" class="coaches-dropdown__all">View all coaches →</a>
            {coaches.map((coach) => (
              <a href={`/coaches/${coach.slug}/`} class="dropdown-item">
                <strong class="dropdown-item__name">{coach.name}</strong>
                <p class="dropdown-item__role">{coach.role}</p>
                <p class="dropdown-item__summary">{coach.summary}</p>
              </a>
            ))}
          </div>
        </li>

        <li style="margin-left: auto">
          <a href="/contact/" class:list={['site-nav__cta', { 'is-active': isActive('/contact/') }]}>
            Contact
          </a>
        </li>
      </ul>
    </nav>

    <a
      href="/programs/#evaluations"
      class="site-header__register"
    >
      <span class="site-header__register-full">Player Evaluation Registration — June 8th</span>
      <span class="site-header__register-short">Evaluation Registration — 6/8</span>
    </a>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    height: var(--header-h);
    overflow: visible;
  }

  .site-header::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: -1;
    background: color-mix(in srgb, var(--color-bg-elevated) 88%, transparent);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--color-border);
  }

  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    height: 100%;
    gap: 1.5rem;
  }

  .site-header__brand {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    text-decoration: none;
    color: inherit;
    align-self: flex-start;
    padding-top: 0.4rem;
  }

  .site-header__brand:hover {
    color: inherit;
  }

  .site-header__logo {
    height: 5.5rem;
    width: 5.5rem;
    object-fit: contain;
    flex-shrink: 0;
    background: var(--color-text-muted);
    border: 3px solid var(--color-accent);
    border-radius: 50%;
    padding: 0.2rem;
  }

.site-header__menu-btn {
    display: none;
    width: 2.75rem;
    height: 2.75rem;
    border-radius: var(--radius-sm);
    border: 1px solid var(--color-border);
    background: var(--color-bg-elevated);
    cursor: pointer;
    align-items: center;
    justify-content: center;
  }

  .site-header__menu-btn:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .site-header__burger {
    width: 1.25rem;
    height: 2px;
    background: var(--color-text);
    position: relative;
  }

  .site-header__burger::before,
  .site-header__burger::after {
    content: '';
    position: absolute;
    left: 0;
    width: 100%;
    height: 2px;
    background: var(--color-text);
    transition: transform 0.2s var(--ease-out);
  }

  .site-header__burger::before { top: -6px; }
  .site-header__burger::after  { top:  6px; }

  .site-nav {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex: 1;
  }

  .site-nav__list {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.25rem 1.25rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .site-nav__link {
    font-size: 0.9rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--color-text-muted);
    padding: 0.35rem 0;
    border-bottom: 2px solid transparent;
    transition:
      color 0.2s var(--ease-out),
      border-color 0.2s var(--ease-out);
  }

  .site-nav__link:hover {
    color: var(--color-text);
  }

  .site-nav__link.is-active {
    color: var(--color-text);
    border-color: var(--color-accent);
  }

  /* ── Programs dropdown ──────────────────────────────────────────────────── */
  .site-nav__has-dropdown {
    position: relative;
  }

  /* Invisible bridge fills the gap so hover isn't lost mid-travel */
  .site-nav__has-dropdown::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    top: 100%;
    height: 0.75rem;
  }

  .programs-dropdown {
    position: absolute;
    top: calc(100% + 0.75rem);
    left: 50%;
    transform: translateX(-50%);
    width: 640px;
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
    display: none;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    z-index: 100;
    overflow: hidden;
  }

  /* Show on hover (desktop) */
  .site-nav__has-dropdown:hover .programs-dropdown,
  .site-nav__has-dropdown:focus-within .programs-dropdown {
    display: grid;
  }

  /* Show when JS adds .is-open (mobile / click) */
  .programs-dropdown.is-open {
    display: grid;
  }

  .dropdown-item {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    padding: 1.25rem;
    text-decoration: none;
    color: inherit;
    border-right: 1px solid var(--color-border);
    transition: background 0.15s var(--ease-out);
  }

  .dropdown-item:last-child {
    border-right: none;
  }

  .dropdown-item:hover {
    background: color-mix(in srgb, var(--color-accent) 6%, var(--color-bg-elevated));
  }

  .dropdown-item__name {
    font-size: 0.88rem;
    font-weight: 700;
    color: var(--color-text);
    line-height: 1.3;
  }

  .dropdown-item__highlights {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .dropdown-item__highlights li {
    font-size: 0.78rem;
    color: var(--color-text-muted);
    line-height: 1.4;
    display: flex;
    align-items: flex-start;
    gap: 0.35rem;
  }

  .dropdown-item__highlights li::before {
    content: '→';
    color: var(--color-accent);
    flex-shrink: 0;
    font-size: 0.7rem;
    margin-top: 0.1em;
  }

  /* ── Coaches dropdown ──────────────────────────────────────────────────── */
  .coaches-dropdown {
    position: absolute;
    top: calc(100% + 0.75rem);
    left: 50%;
    transform: translateX(-50%);
    width: 760px;
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
    display: none;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    z-index: 100;
    overflow: hidden;
  }

  .site-nav__has-dropdown:hover .coaches-dropdown,
  .site-nav__has-dropdown:focus-within .coaches-dropdown {
    display: grid;
  }

  .coaches-dropdown.is-open {
    display: grid;
  }

  .dropdown-item__role {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin: 0;
  }

  .dropdown-item__summary {
    font-size: 0.78rem;
    color: var(--color-text-muted);
    margin: 0;
    line-height: 1.4;
  }

  .coaches-dropdown__all {
    display: none;
    padding: 0.9rem 1.25rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-accent);
    text-decoration: none;
    border-bottom: 1px solid var(--color-border);
  }

  /* Contact CTA pill */
  .site-nav__cta {
    display: inline-flex;
    align-items: center;
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    text-decoration: none;
    padding: 0.4rem 1rem;
    border-radius: 999px;
    border: 2px solid var(--color-accent);
    color: var(--color-accent);
    background: transparent;
    transition:
      background 0.2s var(--ease-out),
      color 0.2s var(--ease-out),
      border-color 0.2s var(--ease-out),
      transform 0.2s var(--ease-out);
  }

  .site-nav__cta:hover {
    background: var(--color-accent);
    color: #111320;
    transform: translateY(-1px);
  }

  .site-nav__cta.is-active {
    background: var(--color-accent);
    color: #111320;
  }

  /* Register CTA pill — filled accent, always visible in header */
  .site-header__register {
    display: inline-flex;
    align-items: center;
    flex-shrink: 0;
    white-space: nowrap;
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    text-decoration: none;
    padding: 0.4rem 1rem;
    border-radius: 999px;
    border: 2px solid var(--color-accent);
    color: #111320;
    background: var(--color-accent);
    transition:
      background 0.2s var(--ease-out),
      transform 0.2s var(--ease-out);
  }

  .site-header__register:hover {
    background: color-mix(in srgb, var(--color-accent) 85%, #fff);
    transform: translateY(-1px);
  }

  .site-header__register-short { display: none; }

  /* ── Mobile ──────────────────────────────────────────────────────────────── */
  @media (max-width: 800px) {
    .site-header__menu-btn {
      display: inline-flex;
    }

    .site-nav {
      position: fixed;
      flex: none;
      z-index: 49;
      inset: var(--header-h) 0 0 0;
      flex-direction: column;
      align-items: stretch;
      padding: 1.5rem;
      background: var(--color-bg-elevated);
      border-bottom: 1px solid var(--color-border);
      transform: translateY(-100%);
      opacity: 0;
      pointer-events: none;
      transition:
        transform 0.35s var(--ease-out),
        opacity 0.25s var(--ease-out);
      overflow-y: auto;
    }

    .site-nav.is-open {
      transform: translateY(0);
      opacity: 1;
      pointer-events: auto;
    }

    .site-nav__list {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
    }

    .site-nav__has-dropdown {
      width: 100%;
    }

    /* On mobile, dropdowns are click-toggled and appear inline */
    .programs-dropdown,
    .coaches-dropdown {
      position: static;
      transform: none;
      width: 100%;
      grid-template-columns: 1fr;
      box-shadow: none;
      border-radius: var(--radius-sm);
      margin-top: 0.25rem;
      display: none;
    }

    .programs-dropdown.is-open,
    .coaches-dropdown.is-open {
      display: grid;
    }

    .coaches-dropdown__all {
      display: block;
    }

    .dropdown-item {
      border-right: none;
      border-bottom: 1px solid var(--color-border);
      padding: 1rem;
    }

    .dropdown-item:last-child {
      border-bottom: none;
    }

    .site-nav__cta {
      margin-top: 0.5rem;
      width: 100%;
      justify-content: center;
    }

    /* Keep register button in the header bar, before the hamburger */
    .site-header__register {
      order: 1;
      margin-left: auto;
      font-size: 0.72rem;
      padding: 0.35rem 0.7rem;
    }

    .site-header__menu-btn {
      order: 2;
    }

    .site-header__register-full { display: none; }
    .site-header__register-short { display: inline; }
  }
</style>

<script>
  const toggle = document.getElementById('nav-toggle');
  const nav    = document.getElementById('site-nav');
  const body   = document.body;

  toggle?.addEventListener('click', () => {
    const open = nav?.classList.toggle('is-open');
    toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
    body.classList.toggle('nav-open', !!open);
  });

  nav?.querySelectorAll('a:not(#programs-trigger):not(#coaches-trigger)').forEach((a) => {
    a.addEventListener('click', () => {
      nav.classList.remove('is-open');
      toggle?.setAttribute('aria-expanded', 'false');
      body.classList.remove('nav-open');
    });
  });

  // Mobile: toggle programs dropdown on trigger click
  const programsTrigger  = document.getElementById('programs-trigger');
  const programsDropdown = document.getElementById('programs-dropdown');

  programsTrigger?.addEventListener('click', (e) => {
    if (window.innerWidth <= 800) {
      e.preventDefault();
      programsDropdown?.classList.toggle('is-open');
    }
  });

  programsDropdown?.querySelectorAll('a').forEach((a) => {
    a.addEventListener('click', () => {
      nav?.classList.remove('is-open');
      toggle?.setAttribute('aria-expanded', 'false');
      body.classList.remove('nav-open');
      programsDropdown.classList.remove('is-open');
    });
  });

  // Mobile: toggle coaches dropdown on trigger click
  const coachesTrigger  = document.getElementById('coaches-trigger');
  const coachesDropdown = document.getElementById('coaches-dropdown');

  coachesTrigger?.addEventListener('click', (e) => {
    if (window.innerWidth <= 800) {
      e.preventDefault();
      coachesDropdown?.classList.toggle('is-open');
    }
  });

  coachesDropdown?.querySelectorAll('a').forEach((a) => {
    a.addEventListener('click', () => {
      nav?.classList.remove('is-open');
      toggle?.setAttribute('aria-expanded', 'false');
      body.classList.remove('nav-open');
      coachesDropdown.classList.remove('is-open');
    });
  });
</script>

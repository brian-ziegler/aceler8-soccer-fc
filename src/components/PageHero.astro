---
type Props = {
  tag?: string;
  title: string;
  lead?: string;
};

const { tag, title, lead } = Astro.props;
---

<section class="page-hero">
  <div class="wrap page-hero__inner">
    {tag && <p class="page-hero__tag">{tag}</p>}
    <h1 class="page-hero__title reveal">{title}</h1>
    {lead && <p class="page-hero__lead reveal reveal-delay-1">{lead}</p>}
    <slot />
  </div>
</section>

<style>
  .page-hero {
    background: var(--color-primary);
    color: #f6f3ec;
    padding-block: clamp(3.5rem, 9vw, 5.5rem);
    position: relative;
    overflow: hidden;
  }

  /* Large ring — soccer ball circle motif, upper-right */
  .page-hero::after {
    content: '';
    position: absolute;
    right: -8%;
    top: -60%;
    width: 55vw;
    max-width: 640px;
    aspect-ratio: 1;
    border-radius: 50%;
    border: 90px solid rgba(255, 255, 255, 0.04);
    pointer-events: none;
  }

  /* Inner ring — orange accent */
  .page-hero::before {
    content: '';
    position: absolute;
    right: 4%;
    top: -20%;
    width: 32vw;
    max-width: 380px;
    aspect-ratio: 1;
    border-radius: 50%;
    border: 3px solid rgba(244, 123, 14, 0.18);
    pointer-events: none;
  }

  .page-hero__inner {
    position: relative;
    z-index: 1;
    max-width: 52rem;
  }

  .page-hero__tag {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin: 0 0 0.85rem;
    padding: 0.3rem 0.75rem;
    border: 1px solid rgba(244, 123, 14, 0.35);
    border-radius: 999px;
  }

  .page-hero__title {
    font-size: clamp(2.25rem, 5vw, 3.5rem);
    font-weight: 750;
    line-height: 1.1;
    letter-spacing: -0.025em;
    color: #ffffff;
    margin: 0 0 1rem;
  }

  .page-hero__lead {
    font-size: clamp(1.05rem, 2vw, 1.2rem);
    color: rgba(246, 243, 236, 0.75);
    margin: 0;
    max-width: 44rem;
    line-height: 1.7;
  }
</style>

---

<button
  type="button"
  class="theme-toggle"
  id="theme-toggle"
  aria-label="Switch color theme"
  title="Switch color theme"
>
  <span class="theme-toggle__icon theme-toggle__icon--sun"  aria-hidden="true">☀</span>
  <span class="theme-toggle__icon theme-toggle__icon--moon" aria-hidden="true">☾</span>
  <span class="theme-toggle__icon theme-toggle__icon--auto" aria-hidden="true">Auto</span>
</button>

<style>
  .theme-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 1.75rem;
    min-width: 1.75rem;
    padding: 0 0.4rem;
    border-radius: var(--radius-sm);
    border: 1px solid var(--color-border);
    background: transparent;
    color: var(--color-text-muted);
    font-size: 0.8rem;
    cursor: pointer;
    transition:
      color 0.2s var(--ease-out),
      border-color 0.2s var(--ease-out);
  }

  .theme-toggle:hover {
    color: var(--color-text);
    border-color: var(--color-primary-muted);
  }

  .theme-toggle:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .theme-toggle__icon {
    line-height: 1;
  }

  /* Default (system): show "Auto" */
  .theme-toggle__icon--sun,
  .theme-toggle__icon--moon { display: none; }
  .theme-toggle__icon--auto  { display: inline; font-weight: 600; letter-spacing: 0.04em; }

  /* Explicit light */
  :global(:root[data-theme='light']) .theme-toggle__icon--sun  { display: inline; }
  :global(:root[data-theme='light']) .theme-toggle__icon--auto { display: none; }

  /* Explicit dark */
  :global(:root[data-theme='dark']) .theme-toggle__icon--moon { display: inline; }
  :global(:root[data-theme='dark']) .theme-toggle__icon--auto { display: none; }
</style>

<script>
  const STORAGE_KEY = 'aceler8-theme';

  function getStored(): 'light' | 'dark' | null {
    const v = localStorage.getItem(STORAGE_KEY);
    return v === 'light' || v === 'dark' ? v : null;
  }

  function applyStored() {
    const stored = getStored();
    if (stored) {
      document.documentElement.setAttribute('data-theme', stored);
    } else {
      document.documentElement.removeAttribute('data-theme');
    }
  }

  function cycle() {
    const current = getStored();
    const systemDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
    // Cycle: system → light → dark → system
    if (current === null) {
      const next = systemDark ? 'light' : 'dark';
      document.documentElement.setAttribute('data-theme', next);
      localStorage.setItem(STORAGE_KEY, next);
    } else if (current === 'light') {
      document.documentElement.setAttribute('data-theme', 'dark');
      localStorage.setItem(STORAGE_KEY, 'dark');
    } else {
      document.documentElement.removeAttribute('data-theme');
      localStorage.removeItem(STORAGE_KEY);
    }
  }

  applyStored();
  document.getElementById('theme-toggle')?.addEventListener('click', cycle);
</script>

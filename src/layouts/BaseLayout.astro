---
import '@/styles/global.css';
import Footer from '@/components/Footer.astro';
import Header from '@/components/Header.astro';
import Seo from '@/components/Seo.astro';
import { siteConfig } from '@/data/site';

type Props = {
  title: string;
  description: string;
  ogImage?: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  preloadImages?: string[];
};

const { title, description, ogImage, jsonLd, preloadImages } = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, siteConfig.url).href;
const gaId = import.meta.env.PUBLIC_GA_ID;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="icon" href="/favicon.png" type="image/png" sizes="32x32" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <Seo
      title={title}
      description={description}
      canonicalUrl={canonicalUrl}
      image={ogImage}
      jsonLd={jsonLd}
    />
    {preloadImages?.map((src) => (
      <link rel="preload" as="image" href={src} />
    ))}
    {gaId && (
      <>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}></script>
        <script define:vars={{ gaId }}>
          window.dataLayer = window.dataLayer || [];
          function gtag() { dataLayer.push(arguments); }
          gtag('js', new Date());
          gtag('config', gaId);
        </script>
      </>
    )}
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
  </body>

  <script>
    // Scroll-triggered reveals
    const revealObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-revealed');
            revealObserver.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.12 }
    );
    document.querySelectorAll('[data-reveal]').forEach((el) => revealObserver.observe(el));

    // Subtle lift on card focus (keyboard nav)
    document.querySelectorAll('.card').forEach((card) => {
      (card as HTMLElement).addEventListener('focusin', () => {
        (card as HTMLElement).style.transform = 'translateY(-4px)';
      });
      (card as HTMLElement).addEventListener('focusout', () => {
        (card as HTMLElement).style.transform = '';
      });
    });
  </script>
</html>

<style is:global>
  .skip-link {
    position: absolute;
    left: 1rem;
    top: -100px;
    padding: 0.5rem 1rem;
    background: var(--color-accent);
    color: #111320;
    font-weight: 700;
    text-decoration: none;
    border-radius: var(--radius-sm);
    z-index: 100;
    transition: top 0.2s var(--ease-out);
  }

  .skip-link:focus {
    top: 1rem;
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }
</style>

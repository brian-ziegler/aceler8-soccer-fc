---
import '@/styles/global.css';
import Footer from '@/components/Footer.astro';
import Header from '@/components/Header.astro';
import Seo from '@/components/Seo.astro';
import { siteConfig } from '@/data/site';

type Props = {
  title: string;
  description: string;
  ogImage?: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
};

const { title, description, ogImage, jsonLd } = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, siteConfig.url).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="icon" href="/favicon.png" type="image/png" sizes="32x32" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <Seo
      title={title}
      description={description}
      canonicalUrl={canonicalUrl}
      image={ogImage}
      jsonLd={jsonLd}
    />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
  </body>

  <script>
    // Scroll-triggered reveals
    const revealObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-revealed');
            revealObserver.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.12 }
    );
    document.querySelectorAll('[data-reveal]').forEach((el) => revealObserver.observe(el));

    // 3D card tilt on mousemove
    const MAX_TILT = 7; // degrees
    document.querySelectorAll('.card').forEach((card) => {
      let raf: number;

      card.addEventListener('mousemove', (e) => {
        const evt = e as MouseEvent;
        const rect = (card as HTMLElement).getBoundingClientRect();
        const cx = rect.left + rect.width / 2;
        const cy = rect.top + rect.height / 2;
        const dx = (evt.clientX - cx) / (rect.width / 2);
        const dy = (evt.clientY - cy) / (rect.height / 2);
        cancelAnimationFrame(raf);
        raf = requestAnimationFrame(() => {
          (card as HTMLElement).style.setProperty('--tilt-x', `${dy * -MAX_TILT}deg`);
          (card as HTMLElement).style.setProperty('--tilt-y', `${dx * MAX_TILT}deg`);
          (card as HTMLElement).style.transition = 'transform 0.08s ease, box-shadow 0.4s var(--ease-out), border-color 0.3s var(--ease-out)';
        });
      });

      card.addEventListener('mouseleave', () => {
        cancelAnimationFrame(raf);
        (card as HTMLElement).style.setProperty('--tilt-x', '0deg');
        (card as HTMLElement).style.setProperty('--tilt-y', '0deg');
        (card as HTMLElement).style.transition = 'transform 0.5s var(--ease-out), box-shadow 0.4s var(--ease-out), border-color 0.3s var(--ease-out)';
      });
    });
  </script>
</html>

<style is:global>
  .skip-link {
    position: absolute;
    left: 1rem;
    top: -100px;
    padding: 0.5rem 1rem;
    background: var(--color-accent);
    color: #0a0f0e;
    font-weight: 700;
    text-decoration: none;
    border-radius: var(--radius-sm);
    z-index: 100;
    transition: top 0.2s var(--ease-out);
  }

  .skip-link:focus {
    top: 1rem;
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }
</style>

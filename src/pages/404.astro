---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page not found"
  description="The page you requested does not exist on Aceler8 Soccer FC."
>
  <section class="wrap missing">
    <p class="tag">404</p>
    <h1>That page isn’t on the pitch.</h1>
    <p class="lead">
      The URL may have moved. Start from the home page or jump to the tournament desk.
    </p>
    <div class="missing__actions">
      <a class="btn btn--primary" href="/">Home</a>
      <a class="btn btn--ghost" href="/tournament-directors/">Tournament desk</a>
    </div>
  </section>
</BaseLayout>

<style>
  .missing {
    padding-block: clamp(4rem, 12vw, 7rem);
    max-width: 32rem;
  }

  .missing__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1.5rem;
  }
</style>

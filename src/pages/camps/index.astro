---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { siteConfig } from '@/data/site';

const programs = [
  {
    tag: 'Summer',
    title: 'Summer Camp',
    dates: 'July – August 2025',
    ages: 'Ages 6–14',
    format: 'Full-day & half-day options',
    desc: 'Our flagship summer program runs over multiple weeks during July and August. Players train twice daily with our coaching staff, focusing on technical skill, small-sided games, and player development fundamentals. Camp concludes with an end-of-week showcase.',
    bullets: [
      'Technical skill sessions each morning',
      'Tactical small-sided games in the afternoon',
      'Guest appearances by Aceler8 alumni',
      'Certificates and awards for all campers',
    ],
    cta: 'Registration opening soon',
    ctaDisabled: true,
  },
  {
    tag: 'Spring',
    title: 'Spring Sessions',
    dates: 'April – June 2025',
    ages: 'Ages 8–14',
    format: '4-week & 8-week tracks',
    desc: 'Spring sessions are intensive 4- or 8-week tracks designed to sharpen specific areas of a player's game ahead of the fall competitive season. Small group sizes ensure each player gets personalized attention.',
    bullets: [
      'Small groups (max 12 players per session)',
      'Position-specific tracks available',
      'Goalkeeper development sessions',
      'Progress report for parents at end of track',
    ],
    cta: 'Registration opening soon',
    ctaDisabled: true,
  },
  {
    tag: 'Year-Round',
    title: 'Academy Clinics',
    dates: 'Ongoing',
    ages: 'Ages 10–16',
    format: 'Monthly weekend clinics',
    desc: 'Monthly Saturday clinics give serious players regular exposure to elite coaching outside of their club team schedule. Academy clinics focus on the advanced technical and tactical content from our competitive curriculum.',
    bullets: [
      'Advanced 1v1, combination play, finishing',
      'Video review of match footage',
      'College and academy pathway guidance',
      'Open to all club affiliations',
    ],
    cta: 'Register for next clinic',
    ctaDisabled: false,
  },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'Camps & Clinics — Aceler8 Soccer FC',
  url: `${siteConfig.url}/camps/`,
};
---

<BaseLayout
  title="Camps & Clinics — Summer Camp, Spring Sessions & Academy Clinics"
  description="Aceler8 Soccer FC offers summer camps, spring development sessions, and year-round academy clinics for players ages 6–16 in Rochester, NY."
  jsonLd={jsonLd}
>
  <article class="page-intro wrap">
    <p class="tag">Camps & Clinics</p>
    <h1 class="reveal">Train like a pro.<br />Learn from ones.</h1>
    <p class="lead reveal reveal-delay-1">
      From summer camps to year-round academy clinics, Aceler8 offers elite development
      programming for players of all levels — no club affiliation required.
    </p>
  </article>

  <section class="wrap programs-section">
    {programs.map((p, i) => (
      <div class="card program-card" data-reveal style={`--reveal-delay: ${i * 0.1}s`}>
        <div class="program-card__header">
          <p class="tag">{p.tag}</p>
          <h2>{p.title}</h2>
          <div class="program-card__meta">
            <span>📅 {p.dates}</span>
            <span>👟 {p.ages}</span>
            <span>🏟️ {p.format}</span>
          </div>
        </div>
        <div class="program-card__body">
          <p class="program-card__desc">{p.desc}</p>
          <ul class="program-card__bullets">
            {p.bullets.map((b) => <li>{b}</li>)}
          </ul>
          {p.ctaDisabled ? (
            <span class="btn btn--ghost program-card__cta--disabled">{p.cta}</span>
          ) : (
            <a href="/contact/" class="btn btn--primary">{p.cta}</a>
          )}
        </div>
      </div>
    ))}
  </section>

  <section class="wrap faq-section">
    <h2 data-reveal>Frequently Asked Questions</h2>
    <div class="faq-grid">
      <div class="faq-item" data-reveal style="--reveal-delay: 0.05s">
        <h3>Do I need to be an Aceler8 club member?</h3>
        <p>No. Our camps and clinics are open to all players regardless of club affiliation. We believe every player in Rochester deserves access to elite coaching.</p>
      </div>
      <div class="faq-item" data-reveal style="--reveal-delay: 0.1s">
        <h3>What should players bring?</h3>
        <p>Cleats, shin guards, a ball, and plenty of water. We'll take care of the rest. A detailed equipment list is sent upon registration.</p>
      </div>
      <div class="faq-item" data-reveal style="--reveal-delay: 0.15s">
        <h3>Are there payment plans available?</h3>
        <p>Yes. We offer flexible payment plans and need-based scholarships. Reach out to discuss options — we want cost to be the last reason a player can't join us.</p>
      </div>
      <div class="faq-item" data-reveal style="--reveal-delay: 0.2s">
        <h3>Where are camps held?</h3>
        <p>All programs are held at our Rochester-area training facilities. Exact location details are shared with registered participants closer to the start date.</p>
      </div>
    </div>
  </section>

  <section class="wrap cta-section" data-reveal>
    <h2>Questions? Get in touch.</h2>
    <p class="lead">
      Our team is happy to help you find the right program for your player's age, level, and
      goals.
    </p>
    <div class="cta-actions">
      <a href="/contact/" class="btn btn--primary">Contact Us</a>
      <a href="/pathway/" class="btn btn--ghost">View Pathway Program</a>
    </div>
  </section>
</BaseLayout>

<style>
  .programs-section {
    padding-block: 3rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .program-card {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 0;
  }

  .program-card__header {
    padding: 2.5rem 2rem 2.5rem 2.5rem;
    border-right: 1px solid var(--color-border);
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .program-card__header h2 {
    margin: 0;
    font-size: 1.75rem;
  }

  .program-card__meta {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    margin-top: 0.5rem;
    font-size: 0.88rem;
    color: var(--color-text-muted);
  }

  .program-card__body {
    padding: 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .program-card__desc {
    margin: 0;
    color: var(--color-text-muted);
    line-height: 1.7;
  }

  .program-card__bullets {
    margin: 0;
    padding-left: 1.2rem;
    color: var(--color-text-muted);
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    font-size: 0.95rem;
    flex: 1;
  }

  .program-card__cta--disabled {
    opacity: 0.5;
    cursor: default;
    pointer-events: none;
  }

  .faq-section {
    padding-block: 1rem 4rem;
  }

  .faq-section h2 {
    margin-bottom: 2rem;
  }

  .faq-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
  }

  .faq-item h3 {
    font-size: 1.05rem;
    margin: 0 0 0.6rem;
  }

  .faq-item p {
    margin: 0;
    color: var(--color-text-muted);
    font-size: 0.95rem;
    line-height: 1.65;
  }

  .cta-section {
    padding-block: 2rem 5rem;
  }

  .cta-section h2 {
    margin: 0 0 0.75rem;
  }

  .cta-section .lead {
    margin: 0 0 1.5rem;
    max-width: 40rem;
    color: var(--color-text-muted);
  }

  .cta-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  @media (max-width: 720px) {
    .program-card {
      grid-template-columns: 1fr;
    }

    .program-card__header {
      border-right: none;
      border-bottom: 1px solid var(--color-border);
      padding: 1.5rem;
    }

    .program-card__body {
      padding: 1.5rem;
    }

    .faq-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

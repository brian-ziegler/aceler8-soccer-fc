---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { coaches } from '@/data/coaches';
import { siteConfig } from '@/data/site';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Coaching staff',
  url: `${siteConfig.url}/coaches/`,
  hasPart: coaches.map((c) => ({
    '@type': 'Person',
    name: c.name,
    jobTitle: c.role,
    url: `${siteConfig.url}/coaches/${c.slug}/`,
  })),
};
---

<BaseLayout
  title="Coaching staff"
  description="Meet the licensed and professional staff leading Aceler8 Soccer FC — Connally Edozien, Betsy Jones, and Carmen Stagnitta."
  jsonLd={jsonLd}
>
  <article class="page-intro wrap">
    <p class="tag">Staff</p>
    <h1>Coaches you can verify.</h1>
    <p class="lead">
      Tournament desks and scouts look for names, licenses, and playing backgrounds. We publish ours
      openly — pulled from the same staff who lead our competitive environment.
    </p>
  </article>

  <section class="wrap coaches-layout">
    {coaches.map((c, i) => (
      <article class:list={['card coach-card', { 'coach-card--featured': i === 0 }]} data-reveal style={`--reveal-delay: ${i * 0.1}s`}>
        <a href={`/coaches/${c.slug}/`} class="coach-card__image-link">
          <img src={c.imageSrc} alt={c.imageAlt} width="800" height="520" loading="lazy" />
        </a>
        <div class="coach-card__body">
          <h2>
            <a href={`/coaches/${c.slug}/`}>{c.name}</a>
          </h2>
          <p class="coach-card__role">{c.role}</p>
          <p class="coach-card__title">{c.title}</p>
          <p class="coach-card__summary">{c.summary}</p>
          {c.credentials && i === 0 && (
            <ul class="coach-card__credentials">
              {c.credentials.map((cr) => <li>{cr}</li>)}
            </ul>
          )}
          <a class="coach-card__more" href={`/coaches/${c.slug}/`}>
            Full bio →
          </a>
        </div>
      </article>
    ))}
  </section>
</BaseLayout>

<style>
  .coaches-layout {
    display: grid;
    gap: 1.5rem;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    padding-bottom: 4rem;
  }

  .coach-card--featured {
    grid-column: 1 / -1;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
  }

  .coach-card--featured .coach-card__image-link img {
    height: 100%;
    aspect-ratio: unset;
  }

  .coach-card--featured .coach-card__body {
    padding: 2rem 2rem 2rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .coach-card--featured h2 {
    font-size: 2rem;
  }

  @media (max-width: 600px) {
    .coach-card--featured {
      grid-template-columns: 1fr;
    }

    .coach-card--featured .coach-card__image-link img {
      aspect-ratio: 4 / 3;
      height: auto;
    }
  }

  .coach-card h2 {
    margin: 0 0 0.35rem;
    font-size: 1.5rem;
  }

  .coach-card h2 a {
    text-decoration: none;
    color: inherit;
  }

  .coach-card h2 a:hover {
    color: var(--color-accent);
  }

  .coach-card__image-link {
    display: block;
    line-height: 0;
    overflow: hidden;
    position: relative;
  }

  .coach-card__image-link:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  /* Gradient overlay that slides up on hover */
  .coach-card__image-link::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(12, 61, 61, 0.55) 0%,
      transparent 60%
    );
    opacity: 0;
    transition: opacity 0.4s var(--ease-out);
  }

  .coach-card:hover .coach-card__image-link::after {
    opacity: 1;
  }

  .coach-card img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    transition: transform 0.55s var(--ease-out);
  }

  .coach-card:hover img {
    transform: scale(1.06);
  }

  .coach-card__body {
    padding: 1.25rem 1.2rem 1.4rem;
  }

  .coach-card__role {
    margin: 0;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .coach-card__title {
    margin: 0.35rem 0 0.75rem;
    color: var(--color-text-muted);
    font-size: 0.95rem;
  }

  .coach-card__summary {
    margin: 0 0 1rem;
    color: var(--color-text-muted);
  }

  .coach-card__credentials {
    margin: 0 0 1rem;
    padding-left: 1.1rem;
    font-size: 0.88rem;
    color: var(--color-text-muted);
  }

  .coach-card__credentials li + li {
    margin-top: 0.25rem;
  }

  .coach-card__more {
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-size: 0.8rem;
  }
</style>

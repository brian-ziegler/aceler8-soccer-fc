---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHero from '@/components/PageHero.astro';
import { coaches } from '@/data/coaches';
import { siteConfig } from '@/data/site';

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: 'Aceler8 FC Coaching Staff — Rochester, NY',
    url: `${siteConfig.url}/coaches/`,
    breadcrumb: {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: siteConfig.url },
        { '@type': 'ListItem', position: 2, name: 'Coaches', item: `${siteConfig.url}/coaches/` },
      ],
    },
  },
  ...coaches.map((c) => ({
    '@context': 'https://schema.org',
    '@type': 'Person',
    name: c.name,
    jobTitle: c.title,
    worksFor: { '@type': 'SportsClub', name: 'Aceler8 FC', url: siteConfig.url },
    url: `${siteConfig.url}/coaches/${c.slug}/`,
    ...(c.imageSrc ? { image: `${siteConfig.url}${c.imageSrc}` } : {}),
    ...(c.credentials?.length ? { hasCredential: c.credentials.map((cr) => ({ '@type': 'EducationalOccupationalCredential', credentialCategory: cr })) } : {}),
  })),
];
---

<BaseLayout
  title="Coaching Staff — Aceler8 FC"
  description="Meet the coaches behind Aceler8 FC in Rochester, NY — Connally Edozien (former MLS), Carmen Stagnitta (U.S. Soccer licensed), Betsy Jones, and Charles Gbeke."
  jsonLd={jsonLd}
>
  <PageHero
    tag="Staff"
    title="Coaches you can verify."
    lead="We publish our staff credentials openly — professional playing backgrounds, U.S. Soccer licenses, and the experience behind every session."
  />

  <section class="wrap coaches-layout">
    {coaches.map((c, i) => {
      const hasPhoto = !!c.imageSrc;
      const isFeatured = i === 0;
      return (
        <article
          class:list={['card coach-card', { 'coach-card--featured': isFeatured, 'coach-card--no-photo': !hasPhoto }]}
          data-reveal
          style={`--reveal-delay: ${i * 0.08}s`}
        >
          {hasPhoto ? (
            <a href={`/coaches/${c.slug}/`} class="coach-card__image-link">
              <img src={c.imageSrc} alt={c.imageAlt} width="800" height="520" loading="lazy" />
            </a>
          ) : (
            <div class="coach-card__photo-placeholder">
              <span class="coach-card__initials">
                {c.name.split(' ').map((n: string) => n[0]).join('')}
              </span>
            </div>
          )}
          <div class="coach-card__body">
            <h2>
              <a href={`/coaches/${c.slug}/`}>{c.name}</a>
            </h2>
            <p class="coach-card__role">{c.role}</p>
            <p class="coach-card__title">{c.title}</p>
            <p class="coach-card__summary">{c.summary}</p>
            {c.credentials && c.credentials.length > 0 && isFeatured && (
              <ul class="coach-card__credentials">
                {c.credentials.map((cr: string) => <li>{cr}</li>)}
              </ul>
            )}
            <a class="coach-card__more" href={`/coaches/${c.slug}/`}>
              Full bio →
            </a>
          </div>
        </article>
      );
    })}
  </section>
</BaseLayout>

<style>
  .coaches-layout {
    display: grid;
    gap: 1.5rem;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    padding-block: 2.5rem 4rem;
  }

  .coach-card--featured {
    grid-column: 1 / -1;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
  }

  .coach-card--featured .coach-card__image-link img {
    height: 100%;
    aspect-ratio: unset;
  }

  .coach-card--featured .coach-card__body {
    padding: 2rem 2rem 2rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .coach-card--featured h2 {
    font-size: 2rem;
  }

  @media (max-width: 600px) {
    .coach-card--featured {
      grid-template-columns: 1fr;
    }

    .coach-card--featured .coach-card__image-link img {
      aspect-ratio: 4 / 3;
      height: auto;
    }
  }

  .coach-card h2 {
    margin: 0 0 0.35rem;
    font-size: 1.5rem;
  }

  .coach-card h2 a {
    text-decoration: none;
    color: inherit;
  }

  .coach-card h2 a:hover {
    color: var(--color-accent);
  }

  .coach-card__image-link {
    display: block;
    line-height: 0;
    overflow: hidden;
    position: relative;
  }

  .coach-card__image-link:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .coach-card__image-link::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(13, 43, 94, 0.55) 0%,
      transparent 60%
    );
    opacity: 0;
    transition: opacity 0.4s var(--ease-out);
  }

  .coach-card:hover .coach-card__image-link::after {
    opacity: 1;
  }

  .coach-card img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    transition: transform 0.55s var(--ease-out);
  }

  .coach-card:hover img {
    transform: scale(1.06);
  }

  /* Photo placeholder for coaches without a photo */
  .coach-card__photo-placeholder {
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-muted) 100%);
    aspect-ratio: 4 / 3;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .coach-card--featured .coach-card__photo-placeholder {
    aspect-ratio: unset;
    height: 100%;
    min-height: 280px;
  }

  .coach-card__initials {
    font-family: var(--font-display);
    font-size: 3.5rem;
    font-weight: 700;
    color: rgba(255, 255, 255, 0.3);
    letter-spacing: -0.02em;
    user-select: none;
  }

  .coach-card__body {
    padding: 1.25rem 1.2rem 1.4rem;
  }

  .coach-card__role {
    margin: 0;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .coach-card__title {
    margin: 0.35rem 0 0.75rem;
    color: var(--color-text-muted);
    font-size: 0.95rem;
  }

  .coach-card__summary {
    margin: 0 0 1rem;
    color: var(--color-text-muted);
  }

  .coach-card__credentials {
    margin: 0 0 1rem;
    padding-left: 1.1rem;
    font-size: 0.88rem;
    color: var(--color-text-muted);
  }

  .coach-card__credentials li + li {
    margin-top: 0.25rem;
  }

  .coach-card__more {
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-size: 0.8rem;
  }
</style>

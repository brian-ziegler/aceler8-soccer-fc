---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { siteConfig } from '@/data/site';
import { coaches } from '@/data/coaches';

const heroImage = '/images/homepage.jpg';

const slides = [
  {
    src: '/images/3323.jpg', w: 1620, h: 1080,
    category: 'Player Spotlight',
    label: '#19 Payton Ziegler',
    cta: 'View Profile',
    href: '/players/payton-ziegler/',
  },
  {
    src: '/images/action-2.png', w: 1023, h: 1537,
    category: null, label: null, cta: null, href: null,
  },
  {
    src: '/images/action-3.png', w: 1023, h: 1537,
    category: 'Fall 2026',
    label: 'Elite Program',
    cta: 'Learn More',
    href: '/programs/#elite',
  },
  {
    src: '/images/action-4.png', w: 1023, h: 1537,
    category: null, label: null, cta: null, href: null,
  },
  {
    src: '/images/action-5.png', w: 1023, h: 1537,
    category: 'Development',
    label: 'Pathway Program',
    cta: 'Get Started',
    href: '/programs/#pathway',
  },
  {
    src: '/images/action-6.png', w: 1023, h: 1537,
    category: null, label: null, cta: null, href: null,
  },
  {
    src: '/images/action-7.jpg', w: 4000, h: 6000,
    category: null, label: null, cta: null, href: null,
  },
  {
    src: '/images/action-8.jpg', w: 1080, h: 1620,
    category: null, label: null, cta: null, href: null,
  },
];

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'SportsClub',
    name: siteConfig.name,
    url: siteConfig.url,
    email: siteConfig.contactEmail,
    foundingDate: '2024',
    sport: 'Soccer',
    description:
      'Youth soccer development club in Rochester, NY offering elite programs, pathway training, summer camps, and free community clinics for players U8–U12.',
    address: {
      '@type': 'PostalAddress',
      addressLocality: siteConfig.city,
      addressRegion: siteConfig.region,
      addressCountry: siteConfig.country,
    },
    areaServed: [
      { '@type': 'City', name: 'Rochester', containedInPlace: { '@type': 'State', name: 'New York' } },
      { '@type': 'City', name: 'Brockport', containedInPlace: { '@type': 'State', name: 'New York' } },
      { '@type': 'City', name: 'Greece', containedInPlace: { '@type': 'State', name: 'New York' } },
    ],
    sameAs: [siteConfig.instagram, siteConfig.facebook],
    employee: coaches.map((c) => ({
      '@type': 'Person',
      name: c.name,
      jobTitle: c.role,
      url: `${siteConfig.url}/coaches/${c.slug}/`,
    })),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'SportsOrganization',
    name: siteConfig.name,
    url: siteConfig.url,
    sport: 'Soccer',
    areaServed: {
      '@type': 'City',
      name: siteConfig.city,
      containedInPlace: { '@type': 'State', name: siteConfig.region },
    },
    sameAs: [siteConfig.instagram, siteConfig.facebook],
  },
];
---

<BaseLayout
  title="Aceler8 FC — Player Development · Rochester, NY"
  description="Aceler8 FC is a youth soccer development club in Rochester, NY — offering elite training, the Pathway Program, summer camps, and free clinics for players U8–U12."
  ogImage={heroImage}
  jsonLd={jsonLd}
>
  <!-- ── Full-bleed hero carousel ─────────────────────────────────────────────── -->
  <section class="hero" id="hero" aria-label="Aceler8 FC highlights">
    {slides.map((slide, i) => (
      <div class="hero-slide" data-index={i} aria-hidden={i !== 0 ? 'true' : 'false'}>
        <img
          src={slide.src}
          alt="Aceler8 FC players in action"
          width={slide.w}
          height={slide.h}
          fetchpriority={i === 0 ? 'high' : 'auto'}
          loading={i === 0 ? 'eager' : 'lazy'}
        />
        <div class="hero-slide__scrim" aria-hidden="true" />
        {(slide.label || slide.cta) && (
          <div class="hero-slide__content">
            {slide.category && <p class="hero-slide__category">{slide.category}</p>}
            {slide.label && <p class="hero-slide__label">{slide.label}</p>}
            {slide.href && slide.cta && (
              <a href={slide.href} class="btn btn--accent hero-slide__cta">{slide.cta}</a>
            )}
          </div>
        )}
      </div>
    ))}

    <!-- Controls bar -->
    <div class="hero__controls" aria-label="Carousel controls">
      <div class="hero__dots" role="tablist" aria-label="Slides">
        {slides.map((_, i) => (
          <button
            class="hero__dot"
            role="tab"
            data-slide={i}
            aria-label={`Go to slide ${i + 1}`}
            aria-selected={i === 0 ? 'true' : 'false'}
          />
        ))}
      </div>
      <div class="hero__arrows">
        <button class="hero__arrow hero__arrow--prev" aria-label="Previous slide">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
        </button>
        <button class="hero__arrow hero__arrow--next" aria-label="Next slide">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
        </button>
      </div>
    </div>
  </section>

  <!-- ── Welcome section ───────────────────────────────────────────────────────── -->
  <section class="welcome-section">
    <div class="wrap welcome-inner">
      <div class="welcome-content">
        <ul class="hero__badges reveal" aria-label="Key club facts">
          <li>Est. 2024</li>
          <li>Rochester, NY</li>
          <li>U8–U12 Programs</li>
        </ul>
        <h1 class="reveal reveal-delay-1">Welcome to the<br />Aceler8 FC Family</h1>
        <p class="welcome-lead reveal reveal-delay-2">
          We build complete soccer players — technically sharp, mentally resilient, and rooted in
          the Rochester community. Elite coaching, a structured development pathway, and a culture
          that puts the whole player first.
        </p>
        <div class="welcome-actions reveal reveal-delay-3">
          <div class="programs-menu">
            <button class="btn btn--accent programs-menu__btn" aria-haspopup="true" aria-expanded="false" id="hero-programs-btn">
              Explore Programs
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
            </button>
            <div class="programs-menu__panel" id="hero-programs-panel" hidden>
              <a href="/programs/#elite" class="programs-menu__item">
                <strong>Aceler8 FC Elite</strong>
                <span>4 sessions/week · single team · top competition</span>
              </a>
              <a href="/programs/#pathway" class="programs-menu__item">
                <strong>Aceler8 FC Pathway</strong>
                <span>2 sessions/week · U8–U11 · path to Elite</span>
              </a>
              <a href="/programs/#training" class="programs-menu__item">
                <strong>Aceler8 Training Sessions</strong>
                <span>9-week program · open to all · no tryouts required</span>
              </a>
            </div>
          </div>
          <a class="btn btn--ghost" href="/coaches/">Meet the staff</a>
        </div>
      </div>
    </div>
  </section>

  <hr class="section-rule" aria-hidden="true" />

  <!-- ── What We Offer ─────────────────────────────────────────────────────── -->
  <section class="section">
    <div class="wrap">
      <div class="section__head">
        <p class="tag">What We Offer</p>
        <h2 class="section-heading">A complete development<br class="rwd-break" /> environment.</h2>
        <p class="section__lead">
          From structured pathway training to high-level competitive programming — Aceler8 FC
          provides the coaching, structure, and pathway every player deserves.
        </p>
      </div>
      <div class="grid-3">
        <article class="card card--pad card--feature" data-reveal style="--reveal-delay: 0s">
          <div class="card-icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="28" height="28"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
          </div>
          <h3>Elite Program</h3>
          <p>
            Four sessions a week, single team commitment, top tournaments. For the player
            who wants to take their game somewhere real.
          </p>
          <a class="btn btn--primary card-cta" href="/programs/#elite">View Elite</a>
        </article>
        <article class="card card--pad card--feature" data-reveal style="--reveal-delay: 0.1s">
          <div class="card-icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="28" height="28"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          </div>
          <h3>Pathway Program</h3>
          <p>
            Two sessions a week, flexible scheduling, a direct path to Elite — for players
            U8–U11 ready to push past recreational soccer.
          </p>
          <a class="btn btn--primary card-cta" href="/programs/#pathway">View Pathway</a>
        </article>
        <article class="card card--pad card--feature" data-reveal style="--reveal-delay: 0.2s">
          <div class="card-icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="28" height="28"><polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/></svg>
          </div>
          <h3>Our Philosophy</h3>
          <p>
            We coach the whole player: technical skill, tactical intelligence, physical literacy,
            and mental resilience. Long-term development always wins.
          </p>
          <a class="btn btn--primary card-cta" href="/about/">Read our story</a>
        </article>
      </div>
    </div>
  </section>

  <!-- ── Coaching staff preview (surface background) ────────────────────────── -->
  <section class="section section--surface">
    <div class="wrap coach-preview">
      <div class="coach-preview__intro">
        <p class="tag">Staff</p>
        <h2 class="section-heading">Coaches you can look up.</h2>
        <p class="section__lead">
          Our leadership blends professional playing experience, classroom pedagogy, and
          U.S. Soccer licensing — and we publish every credential openly.
        </p>
        <a class="btn btn--primary" href="/coaches/">Full coaching staff</a>
      </div>
      <ul class="coach-preview__list">
        {
          coaches.map((c, i) => (
            <li data-reveal style={`--reveal-delay: ${i * 0.1}s`}>
              <a href={`/coaches/${c.slug}/`} class:list={['coach-preview__link', { 'coach-preview__link--lead': i === 0 }]}>
                {c.imageSrc ? (
                  <img
                    src={c.imageSrc}
                    alt={c.name}
                    class="coach-preview__photo"
                    width="64"
                    height="64"
                    loading="lazy"
                  />
                ) : (
                  <span class="coach-preview__photo coach-preview__photo--initials" aria-hidden="true">
                    {c.name.split(' ').map((n: string) => n[0]).join('')}
                  </span>
                )}
                <span class="coach-preview__info">
                  <span class="coach-preview__name">{c.name}</span>
                  <span class="coach-preview__role">{c.role}</span>
                </span>
                <svg class="coach-preview__arrow" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- ── Team photo strip ──────────────────────────────────────────────────── -->
  <section class="team-photo-section" aria-hidden="true">
    <img
      src="/images/team-cheering.png"
      alt="Aceler8 FC team celebrating"
      width="1536"
      height="1024"
      loading="lazy"
      class="team-photo"
    />
    <div class="team-photo__overlay">
      <p class="team-photo__caption">Aceler8 FC — Rochester, NY · Est. 2024</p>
    </div>
  </section>

  <!-- ── Navy CTA band ──────────────────────────────────────────────────────── -->
  <section class="section--dark cta-band">
    <div class="wrap cta-band__inner">
      <div class="cta-band__text" data-reveal>
        <p class="tag">Get Started</p>
        <h2>Ready to join the club?</h2>
        <p>
          Interested in learning more about the Aceler8 FC Difference? Register for camps,
          explore the Pathway Program, or reach out to start a conversation.
        </p>
      </div>
      <div class="cta-band__actions" data-reveal style="--reveal-delay: 0.1s">
        <a class="btn btn--accent" href="/contact/">Contact Us Today</a>
        <a class="btn btn--outline-light" href="/programs/">View All Programs</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ── Full-bleed hero ─────────────────────────────────────────────────────── */
  .hero {
    position: relative;
    width: 100%;
    max-width: 100vw;
    height: clamp(520px, 88svh, 960px);
    /* clip: prevents transformed children from contributing to scroll width */
    overflow: clip;
    background: #020d1a;
  }

  .hero-slide {
    position: absolute;
    inset: 0;
    overflow: clip;
    opacity: 0;
    transition: opacity 1s ease;
  }

  .hero-slide.is-active {
    opacity: 1;
  }

  .hero-slide img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 18%;
    transform-origin: center center;
  }

  .hero-slide.is-active img {
    animation: ken-burns 8s ease-out forwards;
  }

  .hero-slide__scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(3, 9, 20, 0.92) 0%,
      rgba(3, 9, 20, 0.55) 22%,
      rgba(3, 9, 20, 0.15) 48%,
      transparent 68%
    );
  }

  .hero-slide__content {
    position: absolute;
    bottom: 5.5rem;
    left: 0;
    right: 0;
    padding-inline: clamp(1.25rem, 5vw, 4rem);
    max-width: calc(var(--max-w) + 2 * clamp(1.25rem, 5vw, 4rem));
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.6rem;
  }

  .hero-slide__category {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin: 0;
  }

  .hero-slide__label {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3.75rem);
    font-weight: 750;
    color: #ffffff;
    margin: 0;
    line-height: 1.08;
    text-shadow: 0 2px 16px rgba(0, 0, 0, 0.5);
    max-width: 18ch;
  }

  .hero-slide__cta {
    margin-top: 0.4rem;
  }

  /* ── Controls bar ────────────────────────────────────────────────────────── */
  .hero__controls {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 4rem;
    display: flex;
    align-items: center;
    padding-inline: clamp(1.25rem, 5vw, 4rem);
    gap: 1.25rem;
    z-index: 10;
    background: linear-gradient(to top, rgba(3, 9, 20, 0.7) 0%, transparent 100%);
  }

  .hero__dots {
    display: flex;
    gap: 0.5rem;
    align-items: center;
    flex: 1;
  }

  .hero__dot {
    width: 8px;
    height: 8px;
    border-radius: 4px;
    background: rgba(255, 255, 255, 0.35);
    border: none;
    padding: 0;
    cursor: pointer;
    transition: width 0.25s ease;
    flex-shrink: 0;
    position: relative;
    overflow: hidden;
  }

  .hero__dot.is-active {
    background: rgba(244, 123, 14, 0.25);
    width: 26px;
  }

  .hero__dot.is-active::after {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--color-accent);
    transform: scaleX(0);
    transform-origin: left center;
    animation: dot-progress 6s linear forwards;
  }

  @keyframes dot-progress {
    from { transform: scaleX(0); }
    to   { transform: scaleX(1); }
  }

  .hero__dot:hover:not(.is-active) {
    background: rgba(255, 255, 255, 0.65);
  }

  .hero__arrows {
    display: flex;
    gap: 0.5rem;
    flex-shrink: 0;
  }

  .hero__arrow {
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.12);
    border: 1px solid rgba(255, 255, 255, 0.22);
    color: #ffffff;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition:
      background 0.2s ease,
      border-color 0.2s ease;
    flex-shrink: 0;
  }

  .hero__arrow:hover {
    background: rgba(255, 255, 255, 0.28);
    border-color: rgba(255, 255, 255, 0.5);
  }

  .hero__arrow:active {
    background: rgba(255, 255, 255, 0.4);
    transition-duration: 0.08s;
  }

  /* ── Welcome section ─────────────────────────────────────────────────────── */
  .welcome-section {
    padding-block: clamp(3rem, 7vw, 5rem);
    background: var(--color-bg);
  }

  .welcome-inner {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0;
  }

  .welcome-content {
    max-width: 46rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .hero__badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 0.75rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .hero__badges li {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(246, 243, 236, 0.55);
    display: flex;
    align-items: center;
    gap: 0.45rem;
  }

  .hero__badges li + li::before {
    content: '';
    display: block;
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: var(--color-accent);
    opacity: 0.7;
  }

  .welcome-section h1 {
    margin: 0;
    font-size: clamp(2.5rem, 5.5vw, 4rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.0;
    color: var(--color-text);
  }

  .welcome-lead {
    color: var(--color-text-muted);
    font-size: clamp(1rem, 2vw, 1.15rem);
    margin: 0;
    line-height: 1.65;
  }

  .welcome-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: center;
  }

  /* ── Section divider ─────────────────────────────────────────────────────── */
  .section-rule {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 0;
  }

  /* ── Sections ─────────────────────────────────────────────────────────────── */
  .section {
    padding-block: clamp(3.5rem, 9vw, 5.5rem);
  }

  .section--surface {
    background: var(--color-surface);
    border-block: 1px solid var(--color-border);
  }

  .section__head {
    max-width: 40rem;
    margin-bottom: 2.5rem;
  }

  .section__lead {
    color: var(--color-text-muted);
    font-size: 1.1rem;
    margin: 0;
  }

  .rwd-break { display: none; }
  @media (min-width: 640px) { .rwd-break { display: block; } }

  /* ── Feature cards ─────────────────────────────────────────────────────────── */
  .grid-3 {
    display: grid;
    gap: 1.25rem;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
  }

  .card--pad {
    padding: 1.75rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .card--pad h3 {
    margin: 0;
    font-size: 1.25rem;
  }

  .card--pad p {
    color: var(--color-text-muted);
    margin: 0;
    flex: 1;
    line-height: 1.65;
  }

  .card-icon {
    color: var(--color-accent);
    margin-bottom: 0.25rem;
  }

  .card-cta {
    align-self: flex-start;
    margin-top: 0.25rem;
  }

  /* ── Coach preview ────────────────────────────────────────────────────────── */
  .coach-preview {
    display: grid;
    gap: 3rem;
    align-items: start;
    grid-template-columns: 1fr 1fr;
  }

  .coach-preview__intro {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-items: flex-start;
  }

  .coach-preview__intro h2 {
    margin: 0;
  }

  .coach-preview__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .coach-preview__link {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.1rem;
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
    background: var(--color-bg-elevated);
    text-decoration: none;
    color: inherit;
    transition:
      border-color 0.2s var(--ease-out),
      background 0.2s var(--ease-out),
      transform 0.2s var(--ease-out);
  }

  .coach-preview__link--lead {
    border-color: var(--color-accent);
    background: color-mix(in srgb, var(--color-accent) 5%, var(--color-bg-elevated));
  }

  .coach-preview__link:hover {
    border-color: var(--color-primary);
    background: color-mix(in srgb, var(--color-primary) 4%, var(--color-bg-elevated));
    transform: translateX(4px);
  }

  .coach-preview__arrow {
    margin-left: auto;
    flex-shrink: 0;
    color: var(--color-text-muted);
    transition: transform 0.2s var(--ease-out);
  }

  .coach-preview__link:hover .coach-preview__arrow {
    transform: translateX(3px);
    color: var(--color-primary);
  }

  .coach-preview__photo {
    width: 3.25rem;
    height: 3.25rem;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
  }

  .coach-preview__photo--initials {
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-muted) 100%);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.8);
    letter-spacing: 0.05em;
  }

  .coach-preview__link--lead .coach-preview__photo {
    outline: 2.5px solid var(--color-accent);
    outline-offset: 2px;
  }

  .coach-preview__info {

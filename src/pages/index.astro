---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { siteConfig } from '@/data/site';
import { coaches } from '@/data/coaches';

const heroImage = '/images/homepage.jpg';

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'SportsClub',
    name: siteConfig.name,
    url: siteConfig.url,
    email: siteConfig.contactEmail,
    foundingDate: '2024',
    sport: 'Soccer',
    description:
      'Youth soccer development club in Rochester, NY offering elite programs, pathway training, summer camps, and free community clinics for players U8–U12.',
    address: {
      '@type': 'PostalAddress',
      addressLocality: siteConfig.city,
      addressRegion: siteConfig.region,
      addressCountry: siteConfig.country,
    },
    areaServed: [
      { '@type': 'City', name: 'Rochester', containedInPlace: { '@type': 'State', name: 'New York' } },
      { '@type': 'City', name: 'Brockport', containedInPlace: { '@type': 'State', name: 'New York' } },
      { '@type': 'City', name: 'Greece', containedInPlace: { '@type': 'State', name: 'New York' } },
    ],
    sameAs: [siteConfig.instagram, siteConfig.facebook],
    employee: coaches.map((c) => ({
      '@type': 'Person',
      name: c.name,
      jobTitle: c.role,
      url: `${siteConfig.url}/coaches/${c.slug}/`,
    })),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'SportsOrganization',
    name: siteConfig.name,
    url: siteConfig.url,
    sport: 'Soccer',
    areaServed: {
      '@type': 'City',
      name: siteConfig.city,
      containedInPlace: { '@type': 'State', name: siteConfig.region },
    },
    sameAs: [siteConfig.instagram, siteConfig.facebook],
  },
];
---

<BaseLayout
  title="Aceler8 FC — Player Development · Rochester, NY"
  description="Aceler8 FC is a youth soccer development club in Rochester, NY — offering elite training, the Pathway Program, summer camps, and free clinics for players U8–U12."
  ogImage={heroImage}
  jsonLd={jsonLd}
>
  <!-- ── Hero ────────────────────────────────────────────────────────────────── -->
  <section class="hero">
    <div class="hero__media">
      <img
        src={heroImage}
        alt="Aceler8 FC players — Rochester, NY"
        width="6000"
        height="4000"
        fetchpriority="high"
      />
      <div class="hero__scrim" aria-hidden="true"></div>
    </div>
    <div class="wrap hero__content">
      <ul class="hero__badges reveal" aria-label="Key club facts">
        <li>Est. 2024</li>
        <li>Rochester, NY</li>
        <li>U8–U12 Programs</li>
      </ul>
      <h1 class="reveal reveal-delay-1">Welcome to the<br />Aceler8 FC Family</h1>
      <p class="hero__lead reveal reveal-delay-2">
        Aceler8 FC was founded in Rochester, New York in 2024 with a single mission: to develop
        well-rounded soccer players and exceptional human beings. Everything we do — from our
        coaching curriculum to our parent policies — is designed with the whole child in mind.
      </p>
      <div class="hero__actions reveal reveal-delay-3">
        <div class="programs-menu">
          <button class="btn btn--accent programs-menu__btn" aria-haspopup="true" aria-expanded="false" id="hero-programs-btn">
            Explore Programs
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
          </button>
          <div class="programs-menu__panel" id="hero-programs-panel" hidden>
            <a href="/programs/#elite" class="programs-menu__item">
              <strong>Aceler8 FC Elite</strong>
              <span>4 sessions/week · single team · top competition</span>
            </a>
            <a href="/programs/#pathway" class="programs-menu__item">
              <strong>Aceler8 FC Pathway</strong>
              <span>2 sessions/week · U8–U11 · path to Elite</span>
            </a>
            <a href="/programs/#training" class="programs-menu__item">
              <strong>Aceler8 Training Sessions</strong>
              <span>9-week program · open to all · no tryouts required</span>
            </a>
          </div>
        </div>
        <a class="btn btn--outline-light" href="/coaches/">Meet the staff</a>
      </div>
    </div>
  </section>

  <!-- ── Mission ──────────────────────────────────────────────────────────── -->
  <section class="section section--surface">
    <div class="wrap mission-banner">
      <div class="mission-banner__text" data-reveal>
        <p class="tag">Our Mission</p>
        <p class="mission-banner__statement">
          To provide a player-centered, development-focused soccer environment that empowers
          youth in Rochester and the surrounding community to reach their full potential as
          athletes and individuals.
        </p>
      </div>
    </div>
  </section>

  <!-- ── What We Offer ─────────────────────────────────────────────────────── -->
  <section class="section wrap">
    <div class="section__head">
      <p class="tag">What We Offer</p>
      <h2 class="section-heading">A complete development<br class="rwd-break" /> environment.</h2>
      <p class="section__lead">
        From structured pathway training to high-level competitive programming — Aceler8 FC
        provides the coaching, structure, and pathway every player deserves.
      </p>
    </div>
    <div class="grid-3">
      <article class="card card--pad card--feature" data-reveal style="--reveal-delay: 0s">
        <div class="card-icon" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="28" height="28"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
        </div>
        <h3>Elite Program</h3>
        <p>
          Four sessions a week, single team commitment, top tournaments. For the player
          who wants to take their game somewhere real.
        </p>
        <a class="btn btn--primary card-cta" href="/programs/#elite">View Elite</a>
      </article>
      <article class="card card--pad card--feature" data-reveal style="--reveal-delay: 0.1s">
        <div class="card-icon" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="28" height="28"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        </div>
        <h3>Pathway Program</h3>
        <p>
          Two sessions a week, flexible scheduling, a direct path to Elite — for players
          U8–U11 ready to push past recreational soccer.
        </p>
        <a class="btn btn--primary card-cta" href="/programs/#pathway">View Pathway</a>
      </article>
      <article class="card card--pad card--feature" data-reveal style="--reveal-delay: 0.2s">
        <div class="card-icon" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="28" height="28"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
        </div>
        <h3>Our Philosophy</h3>
        <p>
          We coach the whole player: technical skill, tactical intelligence, physical literacy,
          and mental resilience. Long-term development always wins.
        </p>
        <a class="btn btn--primary card-cta" href="/about/">Read our story</a>
      </article>
    </div>
  </section>

  <!-- ── Coaching staff preview (surface background) ────────────────────────── -->
  <section class="section section--surface">
    <div class="wrap coach-preview">
      <div class="coach-preview__intro">
        <p class="tag">Staff</p>
        <h2>Coaches you can look up.</h2>
        <p class="section__lead">
          Our leadership blends professional playing experience, classroom pedagogy, and
          U.S. Soccer licensing — and we publish every credential openly.
        </p>
        <a class="btn btn--primary" href="/coaches/">Full coaching staff</a>
      </div>
      <ul class="coach-preview__list">
        {
          coaches.map((c, i) => (
            <li data-reveal style={`--reveal-delay: ${i * 0.1}s`}>
              <a href={`/coaches/${c.slug}/`} class:list={['coach-preview__link', { 'coach-preview__link--lead': i === 0 }]}>
                {c.imageSrc ? (
                  <img
                    src={c.imageSrc}
                    alt={c.name}
                    class="coach-preview__photo"
                    width="64"
                    height="64"
                    loading="lazy"
                  />
                ) : (
                  <span class="coach-preview__photo coach-preview__photo--initials" aria-hidden="true">
                    {c.name.split(' ').map((n: string) => n[0]).join('')}
                  </span>
                )}
                <span class="coach-preview__info">
                  <span class="coach-preview__name">{c.name}</span>
                  <span class="coach-preview__role">{c.role}</span>
                </span>
                <svg class="coach-preview__arrow" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- ── Team photo strip ──────────────────────────────────────────────────── -->
  <section class="team-photo-section" aria-hidden="true">
    <img
      src="/images/team-cheering.jpg"
      alt="Aceler8 FC team celebrating"
      width="6000"
      height="4000"
      loading="lazy"
      class="team-photo"
    />
    <div class="team-photo__overlay">
      <p class="team-photo__caption">Aceler8 FC — Rochester, NY · Est. 2024</p>
    </div>
  </section>

  <!-- ── Navy CTA band ──────────────────────────────────────────────────────── -->
  <section class="section--dark cta-band">
    <div class="wrap cta-band__inner">
      <div class="cta-band__text" data-reveal>
        <p class="tag">Get Started</p>
        <h2>Ready to join the club?</h2>
        <p>
          Interested in learning more about the Aceler8 FC Difference? Register for camps,
          explore the Pathway Program, or reach out to start a conversation.
        </p>
      </div>
      <div class="cta-band__actions" data-reveal style="--reveal-delay: 0.1s">
        <a class="btn btn--accent" href="/contact/">Contact Us Today</a>
        <a class="btn btn--outline-light" href="/programs/">View All Programs</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ── Hero ─────────────────────────────────────────────────────────────────── */
  .hero {
    position: relative;
    /* Scale hero to the image's natural 3:2 ratio — clamp keeps it usable on
       small screens and prevents it from overflowing tall viewports */
    min-height: clamp(500px, calc(100vw * 2 / 3), 90vh);
    display: flex;
    align-items: flex-start;
    padding-top: clamp(3rem, 7vw, 5rem);
  }

  .hero__media {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
  }

  .hero__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 67%;
    transform-origin: center 67%;
    animation: ken-burns 10s ease-out forwards;
  }

  .hero__scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(8, 14, 30, 0.05) 0%,
      rgba(8, 14, 30, 0.45) 55%,
      rgba(8, 14, 30, 0.82) 100%
    );
  }

  .hero__content {
    position: relative;
    z-index: 1;
    max-width: 44rem;
  }

  /* Trust badges above headline */
  .hero__badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 0.75rem;
    list-style: none;
    margin: 0 0 1.5rem;
    padding: 0;
  }

  .hero__badges li {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(246, 243, 236, 0.65);
    display: flex;
    align-items: center;
    gap: 0.45rem;
  }

  .hero__badges li + li::before {
    content: '';
    display: block;
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: var(--color-accent);
    opacity: 0.7;
  }

  .hero h1 {
    margin: 0 0 1.1rem;
    font-size: clamp(2.8rem, 6vw, 4.5rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.0;
    text-shadow: 0 2px 40px rgba(0, 0, 0, 0.3);
    color: #ffffff;
  }

  .hero__lead {
    color: rgba(246, 243, 236, 0.88);
    font-size: clamp(1rem, 2vw, 1.2rem);
    margin: 0 0 2rem;
    max-width: 36rem;
    line-height: 1.65;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  /* ── Mission banner ──────────────────────────────────────────────────────── */
  .mission-banner {
    display: flex;
    justify-content: center;
  }

  .mission-banner__text {
    max-width: 52rem;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .mission-banner__statement {
    font-family: var(--font-display);
    font-size: clamp(1.1rem, 2vw, 1.4rem);
    font-style: italic;
    font-weight: 500;
    color: var(--color-text);
    line-height: 1.55;
    margin: 0;
  }

  /* ── Sections ─────────────────────────────────────────────────────────────── */
  .section {
    padding-block: clamp(3.5rem, 9vw, 5.5rem);
  }

  .section--surface {
    background: var(--color-surface);
    border-block: 1px solid var(--color-border);
  }

  .section__head {
    max-width: 40rem;
    margin-bottom: 2.5rem;
  }

  .section__lead {
    color: var(--color-text-muted);
    font-size: 1.1rem;
    margin: 0;
  }

  .rwd-break { display: none; }
  @media (min-width: 640px) { .rwd-break { display: block; } }

  /* ── Feature cards ─────────────────────────────────────────────────────────── */
  .grid-3 {
    display: grid;
    gap: 1.25rem;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
  }

  .card--pad {
    padding: 1.75rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .card--pad h3 {
    margin: 0;
    font-size: 1.25rem;
  }

  .card--pad p {
    color: var(--color-text-muted);
    margin: 0;
    flex: 1;
    line-height: 1.65;
  }

  .card-icon {
    color: var(--color-accent);
    margin-bottom: 0.25rem;
  }

  .card-cta {
    align-self: flex-start;
    margin-top: 0.25rem;
  }

  /* ── Coach preview ────────────────────────────────────────────────────────── */
  .coach-preview {
    display: grid;
    gap: 3rem;
    align-items: start;
    grid-template-columns: 1fr 1fr;
  }

  .coach-preview__intro {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-items: flex-start;
  }

  .coach-preview__intro h2 {
    margin: 0;
  }

  .coach-preview__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .coach-preview__link {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.1rem;
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
    background: var(--color-bg-elevated);
    text-decoration: none;
    color: inherit;
    transition:
      border-color 0.2s var(--ease-out),
      background 0.2s var(--ease-out),
      transform 0.2s var(--ease-out);
  }

  .coach-preview__link--lead {
    border-color: var(--color-accent);
    background: color-mix(in srgb, var(--color-accent) 5%, var(--color-bg-elevated));
  }

  .coach-preview__link:hover {
    border-color: var(--color-primary);
    background: color-mix(in srgb, var(--color-primary) 4%, var(--color-bg-elevated));
    transform: translateX(4px);
  }

  .coach-preview__arrow {
    margin-left: auto;
    flex-shrink: 0;
    color: var(--color-text-muted);
    transition: transform 0.2s var(--ease-out);
  }

  .coach-preview__link:hover .coach-preview__arrow {
    transform: translateX(3px);
    color: var(--color-primary);
  }

  .coach-preview__photo {
    width: 3.25rem;
    height: 3.25rem;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
  }

  .coach-preview__photo--initials {
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-muted) 100%);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.8);
    letter-spacing: 0.05em;
  }

  .coach-preview__link--lead .coach-preview__photo {
    outline: 2.5px solid var(--color-accent);
    outline-offset: 2px;
  }

  .coach-preview__info {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .coach-preview__name {
    font-family: var(--font-display);
    font-weight: 650;
    font-size: 1.05rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .coach-preview__role {
    font-size: 0.78rem;
    color: var(--color-text-muted);
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .coach-preview__link--lead .coach-preview__role {
    color: var(--color-accent);
  }

  @media (max-width: 720px) {
    .coach-preview {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }

  /* ── Navy CTA band ───────────────────────────────────────────────────────── */
  .cta-band {
    padding-block: clamp(3.5rem, 9vw, 5.5rem);
  }

  .cta-band__inner {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 3rem 4rem;
    align-items: center;
  }

  .cta-band__text h2 {
    margin: 0.25rem 0 0.75rem;
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
  }

  .cta-band__text p {
    margin: 0;
    max-width: 38rem;
  }

  .cta-band__actions {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    min-width: 180px;
  }

  @media (max-width: 720px) {
    .cta-band__inner {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .cta-band__actions {
      flex-direction: row;
      flex-wrap: wrap;
    }
  }

  /* ── Team photo strip ────────────────────────────────────────────────────── */
  .team-photo-section {
    position: relative;
    height: clamp(280px, 40vw, 480px);
    overflow: hidden;
  }

  .team-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center center;
  }

  .team-photo__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(8, 14, 30, 0.7) 0%,
      rgba(8, 14, 30, 0.1) 50%,
      transparent 100%
    );
    display: flex;
    align-items: flex-end;
    padding: 2rem clamp(1.5rem, 6vw, 4rem);
  }

  .team-photo__caption {
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(246, 243, 236, 0.65);
    margin: 0;
  }

  /* ── Hero programs dropdown ──────────────────────────────────────────────── */
  .programs-menu {
    position: relative;
  }

  .programs-menu__btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    cursor: pointer;
    border: none;
  }

  .programs-menu__panel {
    position: absolute;
    top: calc(100% + 0.5rem);
    left: 0;
    min-width: 260px;
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
    overflow: hidden;
    z-index: 20;
  }

  .programs-menu__item {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    padding: 0.9rem 1.1rem;
    text-decoration: none;
    color: inherit;
    border-bottom: 1px solid var(--color-border);
    transition: background 0.15s var(--ease-out);
  }

  .programs-menu__item:last-child {
    border-bottom: none;
  }

  .programs-menu__item:hover {
    background: color-mix(in srgb, var(--color-accent) 8%, var(--color-bg-elevated));
  }

  .programs-menu__item strong {
    font-size: 0.9rem;
    color: var(--color-text);
  }

  .programs-menu__item span {
    font-size: 0.78rem;
    color: var(--color-text-muted);
  }
</style>

<script>
  const btn   = document.getElementById('hero-programs-btn');
  const panel = document.getElementById('hero-programs-panel');

  btn?.addEventListener('click', () => {
    const expanded = btn.getAttribute('aria-expanded') === 'true';
    btn.setAttribute('aria-expanded', expanded ? 'false' : 'true');
    panel?.toggleAttribute('hidden');
  });

  document.addEventListener('click', (e) => {
    if (!btn?.contains(e.target as Node) && !panel?.contains(e.target as Node)) {
      btn?.setAttribute('aria-expanded', 'false');
      panel?.setAttribute('hidden', '');
    }
  });
</script>

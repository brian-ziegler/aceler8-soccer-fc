---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { siteConfig } from '@/data/site';
import { coaches } from '@/data/coaches';
import { heroSlides as slides } from '@/data/hero-slides';

const heroImage = '/hero/raw/3323.jpg';

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'SportsClub',
    name: siteConfig.name,
    url: siteConfig.url,
    email: siteConfig.contactEmail,
    foundingDate: '2024',
    sport: 'Soccer',
    description:
      'Youth soccer development club in Rochester, NY offering elite programs, pathway training, summer camps, and free community clinics for players U8–U12.',
    address: {
      '@type': 'PostalAddress',
      addressLocality: siteConfig.city,
      addressRegion: siteConfig.region,
      addressCountry: siteConfig.country,
    },
    areaServed: [
      { '@type': 'City', name: 'Rochester', containedInPlace: { '@type': 'State', name: 'New York' } },
      { '@type': 'City', name: 'Brockport', containedInPlace: { '@type': 'State', name: 'New York' } },
      { '@type': 'City', name: 'Greece', containedInPlace: { '@type': 'State', name: 'New York' } },
    ],
    sameAs: [siteConfig.instagram, siteConfig.facebook],
    employee: coaches.map((c) => ({
      '@type': 'Person',
      name: c.name,
      jobTitle: c.role,
      url: `${siteConfig.url}/coaches/${c.slug}/`,
    })),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'SportsOrganization',
    name: siteConfig.name,
    url: siteConfig.url,
    sport: 'Soccer',
    areaServed: {
      '@type': 'City',
      name: siteConfig.city,
      containedInPlace: { '@type': 'State', name: siteConfig.region },
    },
    sameAs: [siteConfig.instagram, siteConfig.facebook],
  },
];
---

<BaseLayout
  title="Aceler8 FC — Player Development · Rochester, NY"
  description="Aceler8 FC — more than just a name, we uphold the shirt. Youth soccer development club in Rochester, NY offering elite training, the Pathway Program, summer camps, and free clinics for players U8–U12."
  ogImage={heroImage}
  jsonLd={jsonLd}
>
  <!-- ── Welcome section ───────────────────────────────────────────────────────── -->
  <section class="welcome-section">
    <div class="wrap welcome-inner">
      <div class="welcome-content">
        <ul class="hero__badges reveal" aria-label="Key club facts">
          <li>Est. 2024</li>
          <li>Rochester, NY</li>
          <li>U8–U12 Programs</li>
        </ul>
        <h1 class="reveal reveal-delay-1">Welcome to the<br />Aceler8 FC Family</h1>
        <p class="welcome-lead reveal reveal-delay-2">
          We build complete soccer players — technically sharp, mentally resilient, and rooted in
          the Rochester community. Elite coaching, a structured development pathway, and a culture
          that puts the whole player first.
        </p>
        <div class="welcome-actions reveal reveal-delay-3">
          <div class="programs-menu">
            <button class="btn btn--accent programs-menu__btn" aria-haspopup="true" aria-expanded="false" id="hero-programs-btn">
              Explore Programs
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
            </button>
            <div class="programs-menu__panel" id="hero-programs-panel" hidden>
              <a href="/programs/#elite" class="programs-menu__item">
                <strong>Aceler8 FC Elite</strong>
                <span>4 sessions/week · single team · top competition</span>
              </a>
              <a href="/programs/#pathway" class="programs-menu__item">
                <strong>Aceler8 FC Pathway</strong>
                <span>2 sessions/week · U8–U11 · path to Elite</span>
              </a>
              <a href="/programs/#training" class="programs-menu__item">
                <strong>Aceler8 Training Sessions</strong>
                <span>9-week program · open to all · no tryouts required</span>
              </a>
            </div>
          </div>
          <a class="btn btn--ghost" href="/coaches/">Meet the staff</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Full-bleed hero carousel ─────────────────────────────────────────────── -->
  <section class="hero" id="hero" aria-label="Aceler8 FC highlights">
    {slides.map((slide, i) => (
      <div class="hero-slide" data-index={i} aria-hidden={i !== 0 ? 'true' : 'false'}>
        <img
          src={slide.src}
          alt="Aceler8 FC players in action"
          width={slide.width}
          height={slide.height}
          fetchpriority={i === 0 ? 'high' : 'auto'}
          loading={i === 0 ? 'eager' : 'lazy'}
        />
        <div class="hero-slide__scrim" aria-hidden="true" />
        {(slide.heading || slide.title || slide.description || slide.button) && (
          <div class="hero-slide__content">
            {slide.heading && <p class="hero-slide__heading">{slide.heading}</p>}
            {slide.title && <p class="hero-slide__title">{slide.title}</p>}
            {slide.description && <p class="hero-slide__description">{slide.description}</p>}
            {slide.button && (
              <a href={slide.button.href} class="btn btn--accent hero-slide__cta">{slide.button.label}</a>
            )}
          </div>
        )}
      </div>
    ))}

    <!-- Hero content overlay — desktop only, welcome section handles mobile -->
    <div class="hero-overlay">
      <div class="hero-overlay__inner">
        <ul class="hero__badges">
          <li>Est. 2024</li>
          <li>Rochester, NY</li>
          <li>U8–U12 Programs</li>
        </ul>
        <h1 class="hero-overlay__heading">Welcome to the<br />Aceler8 FC Family</h1>
        <p class="hero-overlay__lead">
          We build complete soccer players — technically sharp, mentally resilient, and rooted in
          the Rochester community. Elite coaching and a culture that puts the whole player first.
        </p>
        <div class="welcome-actions">
          <a class="btn btn--accent" href="/programs/">Explore Programs</a>
          <a class="btn btn--ghost" href="/coaches/">Meet the Staff</a>
        </div>
      </div>
    </div>

    <!-- Controls bar -->
    <div class="hero__controls" aria-label="Carousel controls">
      <button class="hero__arrow hero__arrow--prev" aria-label="Previous slide">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
      </button>
      <div class="hero__dots" role="tablist" aria-label="Slides">
        {slides.map((_, i) => (
          <button
            class="hero__dot"
            role="tab"
            data-slide={i}
            aria-label={`Go to slide ${i + 1}`}
            aria-selected={i === 0 ? 'true' : 'false'}
          />
        ))}
      </div>
      <button class="hero__arrow hero__arrow--next" aria-label="Next slide">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
      </button>
    </div>
  </section>

  <!-- ── Navy CTA band ──────────────────────────────────────────────────────── -->
  <section class="section--dark cta-band">
    <div class="wrap cta-band__inner">
      <div class="cta-band__text" data-reveal>
        <p class="tag">Get Started</p>
        <h2>Ready to join the club?</h2>
        <p>
          Interested in learning more about the Aceler8 FC Difference? Register for camps,
          explore the Pathway Program, or reach out to start a conversation.
        </p>
      </div>
      <div class="cta-band__actions" data-reveal style="--reveal-delay: 0.1s">
        <a class="btn btn--accent" href="/contact/">Contact Us Today</a>
        <a class="btn btn--outline-light" href="/programs/">View All Programs</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ── Full-bleed hero ─────────────────────────────────────────────────────── */
  .hero {
    position: relative;
    width: 100%;
    max-width: 100vw;
    height: clamp(520px, 88svh, 960px);
    /* clip: prevents transformed children from contributing to scroll width */
    overflow: clip;
    background: #020d1a;
  }

  .hero-slide {
    position: absolute;
    inset: 0;
    overflow: clip;
    opacity: 0;
    transition: opacity 1s ease;
  }

  .hero-slide.is-active {
    opacity: 1;
  }

  .hero-slide img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center center;
    transform-origin: center center;
  }

  .hero-slide.is-active img {
    animation: ken-burns 8s ease-out forwards;
  }

  .hero-slide__scrim {
    position: absolute;
    inset: 0;
    /* Mobile: bottom-up gradient so controls area stays readable */
    background: linear-gradient(
      to top,
      rgba(3, 9, 20, 0.92) 0%,
      rgba(3, 9, 20, 0.55) 22%,
      rgba(3, 9, 20, 0.15) 48%,
      transparent 68%
    );
  }

  @media (min-width: 641px) {
    .hero-slide__scrim {
      /* Desktop: left + right gradients for overlay/controls legibility + subtle bottom */
      background:
        linear-gradient(to right, rgba(3, 9, 20, 0.92) 0%, rgba(3, 9, 20, 0.7) 28%, rgba(3, 9, 20, 0.12) 58%, transparent 75%),
        linear-gradient(to left,  rgba(3, 9, 20, 0.88) 0%, rgba(3, 9, 20, 0.6) 25%, rgba(3, 9, 20, 0.1) 55%, transparent 70%),
        linear-gradient(to top, rgba(3, 9, 20, 0.55) 0%, transparent 18%);
    }
  }

  .hero-slide__content {
    position: absolute;
    bottom: 8rem;
    right: clamp(1.25rem, 5vw, 4rem);
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    text-align: right;
    gap: 0.6rem;
    max-width: min(52%, 42rem);
  }

  .hero-slide__heading {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin: 0;
  }

  .hero-slide__title {
    font-family: var(--font-display);
    font-size: 3rem;
    font-weight: 750;
    color: #ffffff;
    margin: 0;
    line-height: 1.08;
    text-shadow: 0 2px 16px rgba(0, 0, 0, 0.5);
    max-width: 18ch;
  }

  .hero-slide__description {
    font-size: clamp(0.9rem, 1.5vw, 1.05rem);
    color: rgba(246, 243, 236, 0.8);
    margin: 0;
    max-width: 42ch;
    line-height: 1.5;
  }

  .hero-slide__cta {
    margin-top: 0.4rem;
  }

  /* ── Controls bar ────────────────────────────────────────────────────────── */
  .hero__controls {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 4rem;
    display: flex;
    align-items: center;
    justify-content: center;
    padding-inline: 1rem;
    gap: 0.5rem;
    z-index: 10;
    background: linear-gradient(to top, rgba(3, 9, 20, 0.7) 0%, transparent 100%);
  }

  @media (min-width: 641px) {
    .hero__controls {
      left: auto;
      right: clamp(1.25rem, 5vw, 4rem);
      width: auto;
      height: auto;
      bottom: 1.75rem;
      padding-inline: 0;
      justify-content: flex-end;
      background: none;
    }
  }

  .hero__dots {
    display: flex;
    gap: 0.5rem;
    align-items: center;
  }

  .hero__dot {
    width: 16px;
    height: 16px;
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.35);
    border: none;
    padding: 0;
    cursor: pointer;
    transition: width 0.25s ease;
    flex-shrink: 0;
    position: relative;
    overflow: hidden;
  }

  .hero__dot.is-active {
    background: rgba(244, 123, 14, 0.25);
    width: 52px;
  }

  .hero__dot.is-active::after {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--color-accent);
    transform: scaleX(0);
    transform-origin: left center;
    animation: dot-progress 6s linear forwards;
  }

  @keyframes dot-progress {
    from { transform: scaleX(0); }
    to   { transform: scaleX(1); }
  }

  .hero__dot:hover:not(.is-active) {
    background: rgba(255, 255, 255, 0.65);
  }

  .hero__arrow {
    width: 26px;
    height: 26px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.12);
    border: 1px solid rgba(255, 255, 255, 0.22);
    color: #ffffff;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition:
      background 0.2s ease,
      border-color 0.2s ease;
    flex-shrink: 0;
  }

  .hero__arrow:hover {
    background: rgba(255, 255, 255, 0.28);
    border-color: rgba(255, 255, 255, 0.5);
  }

  .hero__arrow:active {
    background: rgba(255, 255, 255, 0.4);
    transition-duration: 0.08s;
  }

  /* ── Hero overlay (desktop only) ─────────────────────────────────────────── */
  .hero-overlay {
    display: none;
  }

  @media (min-width: 641px) {
    .hero-overlay {
      display: flex;
      position: absolute;
      top: 0;
      left: 0;
      bottom: 0;
      width: min(52%, 42rem);
      z-index: 5;
      align-items: center;
      padding-inline: clamp(1.25rem, 5vw, 4rem);
      padding-block: 4rem;
    }

    .hero-overlay__inner {
      display: flex;
      flex-direction: column;
      gap: 1.25rem;
    }

    .hero-overlay__heading {
      margin: 0;
      font-size: clamp(1.6rem, 3vw, 3rem);
      font-weight: 800;
      letter-spacing: -0.03em;
      line-height: 1.05;
      color: #ffffff;
      text-shadow: 0 2px 20px rgba(0, 0, 0, 0.4);
    }

    .hero-overlay__lead {
      color: rgba(246, 243, 236, 0.82);
      font-size: clamp(0.9rem, 1.4vw, 1.05rem);
      margin: 0;
      line-height: 1.65;
      max-width: 36ch;
      text-shadow: 0 1px 8px rgba(0, 0, 0, 0.5);
    }
  }

  /* ── Welcome section (mobile only below hero) ─────────────────────────────── */
  .welcome-section {
    padding-block: clamp(3rem, 7vw, 5rem);
    background: var(--color-bg);
  }

  @media (min-width: 641px) {
    .welcome-section {
      display: none;
    }
  }

  .welcome-inner {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0;
  }

  .welcome-content {
    max-width: 46rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .hero__badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 0.75rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .hero__badges li {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(246, 243, 236, 0.55);
    display: flex;
    align-items: center;
    gap: 0.45rem;
  }

  .hero__badges li + li::before {
    content: '';
    display: block;
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: var(--color-accent);
    opacity: 0.7;
  }

  .welcome-section h1 {
    margin: 0;
    font-size: clamp(2.5rem, 5.5vw, 4rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.0;
    color: var(--color-text);
  }

  .welcome-lead {
    color: var(--color-text-muted);
    font-size: clamp(1rem, 2vw, 1.15rem);
    margin: 0;
    line-height: 1.65;
  }

  .welcome-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: center;
  }

  /* ── Navy CTA band ───────────────────────────────────────────────────────── */
  .cta-band {
    padding-block: clamp(3.5rem, 9vw, 5.5rem);
  }

  .cta-band__inner {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 3rem 4rem;
    align-items: center;
  }

  .cta-band__text h2 {
    margin: 0.25rem 0 0.75rem;
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
  }

  .cta-band__text p {
    margin: 0;
    max-width: 38rem;
  }

  .cta-band__actions {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    min-width: 180px;
  }

  @media (max-width: 720px) {
    .cta-band__inner {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .cta-band__actions {
      flex-direction: row;
      flex-wrap: wrap;
    }
  }

  /* ── Programs dropdown ───────────────────────────────────────────────────── */
  .programs-menu {
    position: relative;
  }

  .programs-menu__btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    cursor: pointer;
    border: none;
  }

  .programs-menu__panel {
    position: absolute;
    top: calc(100% + 0.5rem);
    left: 0;
    min-width: 260px;
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
    overflow: hidden;
    z-index: 20;
  }

  .programs-menu__item {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    padding: 0.9rem 1.1rem;
    text-decoration: none;
    color: inherit;
    border-bottom: 1px solid var(--color-border);
    transition: background 0.15s var(--ease-out);
  }

  .programs-menu__item:last-child {
    border-bottom: none;
  }

  .programs-menu__item:hover {
    background: color-mix(in srgb, var(--color-accent) 8%, var(--color-bg-elevated));
  }

  .programs-menu__item strong {
    font-size: 0.9rem;
    color: var(--color-text);
  }

  .programs-menu__item span {
    font-size: 0.78rem;
    color: var(--color-text-muted);
  }

  /* ── btn--outline-light (used in CTA band) ───────────────────────────────── */
  .btn--outline-light {
    background: transparent;
    color: rgba(246, 243, 236, 0.85);
    border-color: rgba(246, 243, 236, 0.35);
  }

  .btn--outline-light:hover {
    border-color: rgba(246, 243, 236, 0.65);
    background: rgba(246, 243, 236, 0.08);
    color: #ffffff;
    transform: translateY(-3px);
  }

  .btn--outline-light:active {
    transform: translateY(0) scale(0.97);
    transition-duration: 0.08s;
  }

  /* ── Mobile tweaks ───────────────────────────────────────────────────────── */
  @media (max-width: 640px) {
    .hero-slide__content {
      bottom: 4.5rem;
      right: 1rem;
      max-width: calc(100% - 2rem);
    }

    .hero {
      height: clamp(480px, 85svh, 720px);
    }
  }
</style>

<script>
  // ── Hero carousel ────────────────────────────────────────────────────────────
  const heroEl = document.querySelector<HTMLElement>('.hero');
  const slides = Array.from(document.querySelectorAll<HTMLElement>('.hero-slide'));
  const dots = Array.from(document.querySelectorAll<HTMLElement>('.hero__dot'));
  const prevBtn = document.querySelector<HTMLButtonElement>('.hero__arrow--prev');
  const nextBtn = document.querySelector<HTMLButtonElement>('.hero__arrow--next');

  if (slides.length) {
    let current = 0;
    let timer: ReturnType<typeof setInterval> | null = null;

    function goTo(n: number) {
      slides[current].classList.remove('is-active');
      slides[current].setAttribute('aria-hidden', 'true');
      dots[current]?.classList.remove('is-active');
      dots[current]?.setAttribute('aria-selected', 'false');

      current = ((n % slides.length) + slides.length) % slides.length;

      slides[current].classList.add('is-active');
      slides[current].setAttribute('aria-hidden', 'false');
      dots[current]?.classList.add('is-active');
      dots[current]?.setAttribute('aria-selected', 'true');
    }

    function startTimer() {
      if (timer) clearInterval(timer);
      timer = setInterval(() => goTo(current + 1), 6000);
    }

    goTo(0);
    startTimer();

    prevBtn?.addEventListener('click', () => { goTo(current - 1); startTimer(); });
    nextBtn?.addEventListener('click', () => { goTo(current + 1); startTimer(); });
    dots.forEach((dot, i) => {
      dot.addEventListener('click', () => { goTo(i); startTimer(); });
    });

    heroEl?.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'ArrowLeft') { goTo(current - 1); startTimer(); }
      if (e.key === 'ArrowRight') { goTo(current + 1); startTimer(); }
    });
  }

  // ── Programs dropdown ─────────────────────────────────────────────────────
  const btn   = document.getElementById('hero-programs-btn');
  const panel = document.getElementById('hero-programs-panel');

  btn?.addEventListener('click', () => {
    const expanded = btn.getAttribute('aria-expanded') === 'true';
    btn.setAttribute('aria-expanded', expanded ? 'false' : 'true');
    panel?.toggleAttribute('hidden');
  });

  document.addEventListener('click', (e) => {
    if (!btn?.contains(e.target as Node) && !panel?.contains(e.target as Node)) {
      btn?.setAttribute('aria-expanded', 'false');
      panel?.setAttribute('hidden', '');
    }
  });
</script>

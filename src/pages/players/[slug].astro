---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { players } from '@/data/players';
import { siteConfig } from '@/data/site';

export function getStaticPaths() {
  return players.map((player) => ({
    params: { slug: player.slug },
    props: { player },
  }));
}

const { player } = Astro.props;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: player.name,
  url: `${siteConfig.url}/players/${player.slug}/`,
  memberOf: {
    '@type': 'SportsOrganization',
    name: siteConfig.name,
    url: siteConfig.url,
  },
};
---

<BaseLayout
  title={`${player.name} — #${player.number} | ${siteConfig.name}`}
  description={`${player.name}, #${player.number}${player.position ? ` · ${player.position}` : ''} at Aceler8 FC — a player-first youth soccer club in Rochester, NY.`}
  jsonLd={jsonLd}
>
  <article class="wrap player-page">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/teams/">Teams</a>
      <span aria-hidden="true">/</span>
      <span>{player.name}</span>
    </nav>

    <div class="player-page__grid">
      <figure class:list={['card player-page__figure', { 'player-page__figure--no-photo': !player.imageSrc }]}>
        {player.imageSrc ? (
          <img src={player.imageSrc} alt={player.name} width="600" height="800" loading="lazy" />
        ) : (
          <div class="player-page__number-placeholder" aria-hidden="true">
            <span>{player.number}</span>
          </div>
        )}
      </figure>

      <div class="player-page__info">
        <span class="player-page__number" aria-label={`Jersey number ${player.number}`}>
          #{player.number}
        </span>
        <h1 class="player-page__name">{player.name}</h1>
        {player.position && <p class="player-page__position">{player.position}</p>}
        <p class="player-page__club">Aceler8 FC · Rochester, NY</p>
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .player-page {
    padding-bottom: 4rem;
  }

  .breadcrumb {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem 0.65rem;
    font-size: 0.85rem;
    color: var(--color-text-muted);
    padding-block: 1.5rem 1rem;
  }

  .breadcrumb a {
    font-weight: 600;
  }

  .player-page__grid {
    display: grid;
    gap: 2.5rem;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    align-items: start;
  }

  .player-page__figure {
    margin: 0;
  }

  .player-page__figure img {
    width: 100%;
    object-fit: cover;
    object-position: center top;
    max-height: 520px;
  }

  @media (max-width: 600px) {
    .player-page__figure {
      background: #020d1a;
    }

    .player-page__figure img {
      aspect-ratio: 2 / 3;
      max-height: unset;
      object-fit: contain;
    }
  }

  .player-page__number-placeholder {
    aspect-ratio: 3 / 4;
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-muted) 100%);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .player-page__number-placeholder span {
    font-family: var(--font-display);
    font-size: 8rem;
    font-weight: 900;
    color: rgba(255, 255, 255, 0.15);
    letter-spacing: -0.04em;
    user-select: none;
  }

  .player-page__info {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding-top: 0.5rem;
  }

  .player-page__number {
    font-family: var(--font-display);
    font-size: clamp(3rem, 8vw, 6rem);
    font-weight: 900;
    line-height: 1;
    letter-spacing: -0.04em;
    color: var(--color-accent);
  }

  .player-page__name {
    font-size: clamp(1.8rem, 4vw, 3rem);
    font-weight: 750;
    margin: 0;
    line-height: 1.05;
    letter-spacing: -0.03em;
  }

  .player-page__position {
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin: 0.1rem 0 0;
  }

  .player-page__club {
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin: 0.15rem 0 0;
  }
</style>

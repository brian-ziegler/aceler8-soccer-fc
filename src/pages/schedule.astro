---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { siteConfig } from '@/data/site';
---

<BaseLayout
  title="Schedule — competitions & events"
  description="Competition calendar for Aceler8 Soccer FC. Tournament blocks and league play are listed here for directors, families, and scouts."
>
  <article class="page-intro wrap">
    <p class="tag">Schedule</p>
    <h1>Where we’re competing.</h1>
    <p class="lead">
      This page is the public home for our competition calendar. Dates and venues are updated as
      events are confirmed — a lightweight pattern that can later connect to CMS or sports APIs.
    </p>
  </article>

  <section class="wrap schedule">
    <div class="schedule__empty card card--pad">
      <p class="schedule__empty-icon" aria-hidden="true">📅</p>
      <h2>Season schedule coming soon</h2>
      <p>
        Tournament blocks and league dates will appear here as they are confirmed. Check back
        closer to the season — or contact us directly for the latest.
      </p>
      <a href="/contact/" class="btn btn--primary">Contact the club</a>
    </div>
  </section>
</BaseLayout>

<style>
  .schedule {
    padding-bottom: 4rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .card--pad {
    padding: 1.25rem 1.35rem;
  }

  .schedule__empty {
    max-width: 36rem;
    text-align: center;
    padding: 3rem 2rem;
  }

  .schedule__empty-icon {
    font-size: 2.5rem;
    margin: 0 0 1rem;
  }

  .schedule__empty h2 {
    margin: 0 0 0.75rem;
    font-size: 1.35rem;
  }

  .schedule__empty p {
    color: var(--color-text-muted);
    margin: 0 0 1.5rem;
  }
</style>

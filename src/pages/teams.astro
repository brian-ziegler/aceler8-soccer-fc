---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHero from '@/components/PageHero.astro';
import { siteConfig } from '@/data/site';

const ageGroups = [
  { group: 'U8', format: '4v4', season: 'Fall 2025', status: 'Recreational — Forming' },
  { group: 'U10', format: '7v7', season: 'Fall 2025', status: 'Recreational — Forming' },
  { group: 'U11', format: '9v9', season: 'Fall 2025', status: 'Competitive — Active' },
  { group: 'U12', format: '9v9', season: 'Fall 2025', status: 'Competitive — Forming' },
  { group: 'U13', format: '11v11', season: 'Fall 2025', status: 'Competitive — Forming' },
  { group: 'U14', format: '11v11', season: 'Fall 2025', status: 'Competitive — Forming' },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'Teams — Aceler8 Soccer FC',
  url: `${siteConfig.url}/teams/`,
};
---

<BaseLayout
  title="Teams — Age Groups & Rosters"
  description="Aceler8 Soccer FC fields recreational and competitive teams for players U8 through U14 in Rochester, NY. Find your age group and learn more about our program."
  jsonLd={jsonLd}
>
  <PageHero
    tag="Our Teams"
    title="Built for every level."
    lead="Aceler8 Soccer FC offers both recreational and competitive programming for players U8 through U14. All teams follow our player-first development model."
  />

  <section class="wrap teams-section">
    <h2 data-reveal>Age Groups</h2>
    <p class="lead" data-reveal style="--reveal-delay: 0.1s">
      Current and upcoming teams for the 2025 season.
    </p>

    <div class="age-table-wrap card" data-reveal style="--reveal-delay: 0.15s">
      <table class="age-table">
        <thead>
          <tr>
            <th>Age Group</th>
            <th>Format</th>
            <th>Season</th>
            <th>Status</th>
          </tr>
        </thead>
        <tbody>
          {
            ageGroups.map((row) => (
              <tr>
                <td class="group-cell">
                  <strong>{row.group}</strong>
                </td>
                <td>{row.format}</td>
                <td>{row.season}</td>
                <td>
                  <span
                    class:list={[
                      'status-badge',
                      row.status.includes('Active') ? 'status-badge--active' : 'status-badge--forming',
                    ]}
                  >
                    {row.status}
                  </span>
                </td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>
  </section>

  <section class="wrap levels-section">
    <div class="levels-grid">
      <div class="card level-card" data-reveal>
        <p class="tag">Recreational</p>
        <h3>Learn the game</h3>
        <p>
          Our recreational program is the perfect entry point for players new to soccer or
          those looking for a fun, low-pressure environment. We focus on fundamentals,
          teamwork, and a love for the game.
        </p>
        <ul>
          <li>Open to all skill levels</li>
          <li>Focus on fun and fundamentals</li>
          <li>Age-appropriate small-sided formats</li>
          <li>Qualified coaching staff</li>
        </ul>
        <a href="/contact/" class="btn btn--ghost">Get in touch</a>
      </div>

      <div class="card level-card" data-reveal style="--reveal-delay: 0.1s">
        <p class="tag">Competitive</p>
        <h3>Elevate your game</h3>
        <p>
          Our competitive teams are for players who want to push themselves further. We compete
          in regional leagues and tournaments, following a structured development model built
          around PDI and LTAD principles.
        </p>
        <ul>
          <li>Tryout / evaluation required</li>
          <li>League and tournament play</li>
          <li>Higher training frequency</li>
          <li>Clear pathway to advanced levels</li>
        </ul>
        <a href="/pathway/" class="btn btn--primary">View Pathway Program</a>
      </div>
    </div>
  </section>

  <section class="wrap cta-section" data-reveal>
    <h2>Interested in joining?</h2>
    <p class="lead">
      Reach out to learn about current roster spots, tryout dates, and registration details.
    </p>
    <div class="cta-actions">
      <a href="/contact/" class="btn btn--primary">Contact Us</a>
      <a href="/coaches/" class="btn btn--ghost">Meet the Coaches</a>
    </div>
  </section>
</BaseLayout>

<style>
  .teams-section {
    padding-block: 2.5rem 3rem;
  }

  .age-table-wrap {
    margin-top: 1.5rem;
    overflow-x: auto;
    padding: 0;
  }

  .age-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.95rem;
  }

  .age-table th {
    text-align: left;
    padding: 1rem 1.25rem;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    border-bottom: 1px solid var(--color-border);
    white-space: nowrap;
  }

  .age-table td {
    padding: 1rem 1.25rem;
    border-bottom: 1px solid var(--color-border);
    color: var(--color-text-muted);
  }

  .age-table tr:last-child td {
    border-bottom: none;
  }

  .age-table tr:hover td {
    background: var(--color-surface);
  }

  .group-cell strong {
    color: var(--color-text);
    font-size: 1rem;
  }

  .status-badge {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    padding: 0.25rem 0.65rem;
    border-radius: 999px;
  }

  .status-badge--active {
    background: rgba(34, 197, 94, 0.12);
    color: #16a34a;
  }

  .status-badge--forming {
    background: var(--color-accent-soft);
    color: var(--color-accent);
  }

  .levels-section {
    padding-block: 1rem 3rem;
  }

  .levels-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  .level-card {
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .level-card h3 {
    margin: 0;
    font-size: 1.4rem;
  }

  .level-card p {
    margin: 0;
    color: var(--color-text-muted);
    line-height: 1.65;
  }

  .level-card ul {
    margin: 0;
    padding-left: 1.2rem;
    color: var(--color-text-muted);
    font-size: 0.95rem;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    flex: 1;
  }

  .cta-section {
    padding-block: 2rem 5rem;
  }

  .cta-section h2 {
    margin: 0 0 0.75rem;
  }

  .cta-section .lead {
    margin: 0 0 1.5rem;
    max-width: 38rem;
    color: var(--color-text-muted);
  }

  .cta-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  @media (max-width: 640px) {
    .levels-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
